<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>LibUsbDotNet</id>
    <version>3.0.154-alpha</version>
    <authors>Travis Robinson,Stevie-O,Quamotion</authors>
    <license type="expression">LGPL-3.0-or-later</license>
    <licenseUrl>https://licenses.nuget.org/LGPL-3.0-or-later</licenseUrl>
    <projectUrl>https://github.com/LibUsbDotNet/LibUsbDotNet/</projectUrl>
    <iconUrl>http://c.fsdn.com/allura/p/libusbdotnet/icon</iconUrl>
    <description>.NET USB library, which acts as a wrapper for libusb-1.0. You can write applications that with on all operating systems and drivers without modification. Lots of example code. Open source software hosted on GitHub.</description>
    <repository type="git" url="https://github.com/LibUsbDotNet/LibUsbDotNet" commit="4bd58cacd857f2497f5848a28bf59ea50f6c9d0d" />
    <dependencies>
      <group targetFramework="net6.0" />
      <group targetFramework="net7.0" />
      <group targetFramework=".NETStandard2.0">
        <dependency id="IndexRange" version="1.0.2" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Bcl.HashCode" version="1.1.1" exclude="Build,Analyzers" />
        <dependency id="System.Memory" version="4.5.5" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>