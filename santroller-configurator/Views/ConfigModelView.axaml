            <DataTemplate DataType="{x:Type output:BluetoothOutput}">
                <StackPanel>
                    <Button Content="{Binding ScanText}" IsEnabled="{Binding !Scanning}"
                            Command="{Binding ScanCommand}" />
                    <StackPanel Orientation="Horizontal">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="300" Content="{x:Static netCore:Resources.SelectedDeviceLabel}" />
                        <ComboBox VerticalAlignment="Center"
                                  SelectedItem="{Binding $parent[UserControl].((viewModels:ConfigViewModel)DataContext).BtRxAddr}"
                                  ItemsSource="{Binding Addresses}"
                                  Width="200" />
                    </StackPanel>
                </StackPanel>
            </DataTemplate>
            <DataTemplate DataType="{x:Type combined:Ps2CombinedOutput}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="300" Content="{x:Static netCore:Resources.PS2KramerModeLabel}" />

                        <ToggleSwitch HorizontalAlignment="Center" Width="200"
                                      HorizontalContentAlignment="Center"
                                      IsChecked="{Binding Model.Ps2KramerMode}"
                                      OnContent="{x:Static netCore:Resources.OnLabel}"
                                      OffContent="{x:Static netCore:Resources.OffLabel}" />
                    </StackPanel>
                    <StackPanel IsVisible="{Binding BindableSpi}" Orientation="Horizontal">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="300" Content="{x:Static netCore:Resources.MosiLabel}" />
                        <ComboBox VerticalAlignment="Center"
                                  SelectedItem="{Binding Mosi}"
                                  ItemsSource="{Binding AvailableMosiPins}"
                                  DropDownOpened="ReloadPinTemplates"
                                  ItemTemplate="{StaticResource PinToStringTemplate}"
                                  Width="200" />
                    </StackPanel>

                    <StackPanel IsVisible="{Binding BindableSpi}" Orientation="Horizontal">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="300" Content="{x:Static netCore:Resources.MisoLabel}" />
                        <ComboBox VerticalAlignment="Center"
                                  SelectedItem="{Binding Miso}"
                                  ItemsSource="{Binding AvailableMisoPins}"
                                  ItemTemplate="{StaticResource PinToStringTemplate}"
                                  Width="200" />
                    </StackPanel>

                    <StackPanel IsVisible="{Binding BindableSpi}" Orientation="Horizontal">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="300" Content="{x:Static netCore:Resources.SckLabel}" />
                        <ComboBox VerticalAlignment="Center"
                                  SelectedItem="{Binding Sck}"
                                  ItemsSource="{Binding AvailableSckPins}"
                                  DropDownOpened="ReloadPinTemplates"
                                  ItemTemplate="{StaticResource PinToStringTemplate}"
                                  Width="200" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                IsVisible="{Binding !$parent[views:ConfigView].((viewModels:ConfigViewModel)DataContext).Branded}">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="300" Content="{x:Static netCore:Resources.AckLabel}" />
                        <ComboBox VerticalAlignment="Center"
                                  SelectedItem="{Binding Ack}"
                                  ItemsSource="{Binding AvailablePinsInterrupt}"
                                  ItemTemplate="{StaticResource PinToStringTemplate}"
                                  DropDownOpened="ReloadPinTemplates"
                                  Width="200" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                IsVisible="{Binding BindableAtt}">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="300" Content="{x:Static netCore:Resources.AttentionLabel}" />
                        <ComboBox VerticalAlignment="Center"
                                  SelectedItem="{Binding Att}"
                                  ItemsSource="{Binding AvailablePins}"
                                  ItemTemplate="{StaticResource PinToStringTemplate}"
                                  DropDownOpened="ReloadPinTemplates"
                                  Width="200" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="300" Content="{x:Static netCore:Resources.PS2InputFilterLabel}" />
                        <ComboBox VerticalAlignment="Center"
                                  SelectedItem="{Binding SelectedType}"
                                  ItemsSource="{Binding Ps2ControllerTypes}"
                                  ItemTemplate="{StaticResource EnumToStringTemplate}"
                                  Width="200" />
                    </StackPanel>
                </StackPanel>
            </DataTemplate>
            <DataTemplate />
        </netCore:OutputTemplateSelector>
        <DataTemplate DataType="output:Output" x:Key="OutputTemplate">
            <StackPanel Opacity="{Binding CombinedOpacity}">
                <Panel>
                    <StackPanel>
                        <Label HorizontalAlignment="Center" IsVisible="{Binding ChildOfCombined}"
                               Content="{Binding Title}" />
                        <StackPanel Orientation="Horizontal">
                            <ContentControl IsVisible="{Binding ChildOfCombined}"
                                            ContentTemplate="{StaticResource ImageOutputTemplate}"
                                            HorizontalAlignment="Left" Width="75" Margin="0 0 10 10"
                                            Content="{Binding }" />
                        </StackPanel>
                    </StackPanel>
                    <ToggleSwitch HorizontalAlignment="Right" IsVisible="{Binding ShouldShowEnabled}"
                                  IsChecked="{Binding Enabled}" OnContent="{x:Static netCore:Resources.EnabledLabel}"
                                  OffContent="{x:Static netCore:Resources.DisabledLabel}" />
                </Panel>
                <ContentControl Content="{Binding Input}"
                                ContentTemplate="{StaticResource OutputTemplates}" />

                <ContentControl Content="{Binding}"
                                ContentTemplate="{StaticResource OutputTemplates}" />
                <WrapPanel Orientation="Horizontal">
                    <WrapPanel.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="AreLedsEnabled" />
                            <Binding Path="!IsCombined" />
                        </MultiBinding>
                    </WrapPanel.IsVisible>
                    <Label VerticalAlignment="Center"
                           VerticalContentAlignment="Center" Width="300" IsVisible="{Binding IsApa102 }"
                           Content="{x:Static netCore:Resources.SelectedLEDsApa102Label}" />
                    <Label VerticalAlignment="Center"
                           VerticalContentAlignment="Center" Width="300" IsVisible="{Binding IsWs2812 }"
                           Content="{x:Static netCore:Resources.SelectedLEDsWS2812Label}" />
                    <Label VerticalAlignment="Center"
                           VerticalContentAlignment="Center" Width="300" IsVisible="{Binding IsStp }"
                           Content="{x:Static netCore:Resources.SelectedLEDsStpLabel}" />
                    <ItemsControl ItemsSource="{Binding AvailableIndices}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="output:LedIndex">
                                <ToggleButton IsChecked="{Binding Selected }"
                                              Content="{Binding Index}" Width="50" HorizontalContentAlignment="Center" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </WrapPanel>
                <WrapPanel Orientation="Horizontal">
                    <WrapPanel.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="AreLedsEnabledPeripheral" />
                            <Binding Path="!IsCombined" />
                        </MultiBinding>
                    </WrapPanel.IsVisible>
                    <Label VerticalAlignment="Center"
                           VerticalContentAlignment="Center" Width="300" IsVisible="{Binding IsApa102Peripheral }"
                           Content="{x:Static netCore:Resources.SelectedLEDsPeripheralApa102Label}" />
                    <Label VerticalAlignment="Center"
                           VerticalContentAlignment="Center" Width="300" IsVisible="{Binding IsWs2812Peripheral }"
                           Content="{x:Static netCore:Resources.SelectedLEDsPeripheralWS2812Label}" />
                    <Label VerticalAlignment="Center"
                           VerticalContentAlignment="Center" Width="300" IsVisible="{Binding IsStpPeripheral }"
                           Content="{x:Static netCore:Resources.SelectedLEDsPeripheralStpLabel}" />
                    <ItemsControl ItemsSource="{Binding AvailableIndicesPeripheral}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="output:LedIndex">
                                <ToggleButton IsChecked="{Binding Selected }"
                                              Content="{Binding Index}" Width="50" HorizontalContentAlignment="Center" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </WrapPanel>
                <WrapPanel Orientation="Horizontal">
                    <WrapPanel.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="Model.HasMpr121" />
                            <Binding Path="!IsCombined" />
                        </MultiBinding>
                    </WrapPanel.IsVisible>
                    <Label VerticalAlignment="Center"
                           VerticalContentAlignment="Center" Width="300"
                           Content="{x:Static netCore:Resources.SelectedLEDsMpr121Label}" />
                    <ItemsControl ItemsSource="{Binding AvailableIndicesMpr121}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="output:LedIndex">
                                <ToggleButton IsChecked="{Binding Selected }"
                                              Content="{Binding Index}" Width="50" HorizontalContentAlignment="Center" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </WrapPanel>
                <StackPanel Orientation="Horizontal">
                    <StackPanel.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                <Binding Path="!IsApa102" />
                                <Binding Path="!IsApa102Peripheral" />
                            </MultiBinding>
                            <Binding Path="!IsCombined" />
                            <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                <Binding Path="AreLedsEnabled" />
                                <Binding Path="AreLedsEnabledPeripheral" />
                            </MultiBinding>
                        </MultiBinding>
                    </StackPanel.IsVisible>
                    <Label VerticalAlignment="Center"
                           VerticalContentAlignment="Center" Width="300"
                           Content="{x:Static netCore:Resources.TestLEDLabel}" />
                    <Button HorizontalAlignment="Center"
                            Width="200"
                            Command="{Binding TestLEDs}"
                            HorizontalContentAlignment="Center" Content="{x:Static netCore:Resources.TestLEDLabel}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <StackPanel.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                <Binding Path="LedsUseColours" />
                                <Binding Path="LedsUseColoursPeripheral" />
                            </MultiBinding>
                            <Binding Path="!IsCombined" />
                            <Binding Path="LedsHaveColours" />
                        </MultiBinding>
                    </StackPanel.IsVisible>
                    <Label VerticalAlignment="Center"
                           VerticalContentAlignment="Center" Width="300"
                           Content="{Binding LedOnLabel}" />

                    <StackPanel Orientation="Horizontal">
                        <ColorPicker IsAlphaEnabled="False" IsAlphaVisible="False" ColorSpectrumShape="Ring"
                                     Color="{Binding LedOn}" />

                        <Button Command="{Binding CopyOff}"
                                HorizontalAlignment="Stretch" Width="300" HorizontalContentAlignment="Center"
                                Content="{x:Static netCore:Resources.CopyOtherLedLabel}" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <StackPanel.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                <Binding Path="LedsUseColours" />
                                <Binding Path="LedsUseColoursPeripheral" />
                            </MultiBinding>
                            <Binding Path="!IsCombined" />
                            <Binding Path="LedsHaveColours" />
                        </MultiBinding>
                    </StackPanel.IsVisible>
                    <Label VerticalAlignment="Center"
                           VerticalContentAlignment="Center" Width="300"
                           Content="{Binding LedOffLabel}" />
                    <ColorPicker IsAlphaEnabled="False" IsAlphaVisible="False" ColorSpectrumShape="Ring"
                                 Color="{Binding LedOff}" />
                    <Button Command="{Binding CopyOn}"
                            HorizontalAlignment="Stretch" Width="300" HorizontalContentAlignment="Center"
                            Content="{x:Static netCore:Resources.CopyOtherLedLabel}" />
                </StackPanel>
                <StackPanel>
                    <StackPanel.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="!IsCombined" />
                            <Binding Path="!UsesPwm" />
                        </MultiBinding>
                    </StackPanel.IsVisible>
                    <StackPanel Orientation="Horizontal" IsVisible="{Binding LedsHaveColours}">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="300" Content="{x:Static netCore:Resources.EnableDigitalOutputTitle}" />
                        <ToggleSwitch IsChecked="{Binding OutputEnabled}"
                                      OnContent="{x:Static netCore:Resources.EnabledLabel}"
                                      OffContent="{x:Static netCore:Resources.DisabledLabel}" />
                    </StackPanel>
                </StackPanel>
                <StackPanel IsVisible="{Binding UsesPwm}">
                    <StackPanel Orientation="Horizontal" IsVisible="{Binding LedsHaveColours}">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="300" Content="{x:Static netCore:Resources.EnableAnalogOutputTitle}" />
                        <ToggleSwitch IsChecked="{Binding OutputEnabled}"
                                      OnContent="{x:Static netCore:Resources.EnabledLabel}"
                                      OffContent="{x:Static netCore:Resources.DisabledLabel}" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" IsVisible="{Binding OutputEnabled}">
                    <Label VerticalAlignment="Center"
                           VerticalContentAlignment="Center"
                           Width="300" Content="{x:Static netCore:Resources.InvertOutputLabel}" />
                    <ToggleSwitch IsChecked="{Binding OutputInverted}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <StackPanel.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="Model.HasPeripheral" />
                            <Binding Path="OutputEnabled" />
                        </MultiBinding>
                    </StackPanel.IsVisible>
                    <Label VerticalAlignment="Center"
                           VerticalContentAlignment="Center"
                           Width="300" Content="{x:Static netCore:Resources.PeripheralOutputLabel}" />
                    <ToggleSwitch IsChecked="{Binding PeripheralOutput}" />
                </StackPanel>
                <StackPanel IsVisible="{Binding UsesPwm}">
                    <StackPanel Orientation="Horizontal" IsVisible="{Binding OutputEnabled}">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               IsVisible="{Binding UsesPwm}"
                               Width="300" Content="{x:Static netCore:Resources.TestLabel}" />
                        <Slider Value="{Binding Test}"
                                Minimum="1"
                                Maximum="255"
                                IsSnapToTickEnabled="True"
                                TickFrequency="1" Width="240" />
                    </StackPanel>
                </StackPanel>
                <StackPanel IsVisible="{Binding !UsesPwm}">
                    <StackPanel Orientation="Horizontal" IsVisible="{Binding OutputEnabled}">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               IsVisible="{Binding !UsesPwm}"
                               Width="300" Content="{x:Static netCore:Resources.TestLabelDigital}" />
                        <ToggleSwitch IsChecked="{Binding TestDigital}" />
                    </StackPanel>
                </StackPanel>
                <StackPanel IsVisible="{Binding UsesPwm}">
                    <StackPanel Orientation="Horizontal" IsVisible="{Binding OutputEnabled}">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="300" Content="{x:Static netCore:Resources.AnalogOutputPinLabel}" />
                        <ComboBox VerticalAlignment="Center"
                                  SelectedItem="{Binding OutputPin}"
                                  DropDownOpened="ReloadPinTemplates"
                                  ItemTemplate="{StaticResource PinToStringTemplate}"
                                  ItemsSource="{Binding AvailablePwmPins}" />
                    </StackPanel>
                </StackPanel>
                <StackPanel IsVisible="{Binding !UsesPwm}">
                    <StackPanel Orientation="Horizontal" IsVisible="{Binding OutputEnabled}">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="300" Content="{x:Static netCore:Resources.DigitalOutputPinLabel}" />
                        <ComboBox VerticalAlignment="Center"
                                  SelectedItem="{Binding OutputPin}"
                                  DropDownOpened="ReloadPinTemplates"
                                  ItemTemplate="{StaticResource PinToStringTemplate}"
                                  ItemsSource="{Binding AvailablePins}" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </DataTemplate>
        <DataTemplate DataType="output:Output" x:Key="CombinedOutputTemplate">
            <ContentControl Content="{Binding}"
                            ContentTemplate="{StaticResource OutputTemplate}" Background="{Binding CombinedBackground}"
                            Padding="10" Margin="0 5 10 5" Width="720" />
        </DataTemplate>
        <DataTemplate DataType="output:Output" x:Key="DigitalOutputTemplate">
            <StackPanel Opacity="{Binding CombinedOpacity}">
                <Panel>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ContentControl ContentTemplate="{StaticResource ImageOutputTemplate}"
                                            HorizontalAlignment="Left" Width="75" Margin="0 0 10 10"
                                            Content="{Binding }" />
                        </StackPanel>
                    </StackPanel>
                </Panel>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>
    <Panel>
        <ScrollViewer VerticalContentAlignment="Center">
            <StackPanel>
                <Expander HorizontalAlignment="Stretch" Header="{Binding}"
                          IsExpanded="{Binding ControllerConfigExpanded}">
                    <Expander.HeaderTemplate>
                        <DataTemplate DataType="viewModels:ConfigViewModel">
                            <Panel>
                                <StackPanel Orientation="Horizontal">
                                    <Image Width="75"
                                           Source="avares://SantrollerConfigurator/Assets/Icons/Generic.png">
                                    </Image>
                                    <Label VerticalAlignment="Center"
                                           VerticalContentAlignment="Center"
                                           Content="{x:Static netCore:Resources.ControllerSettingsLabel}" />
                                </StackPanel>
                            </Panel>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <StackPanel>
                        <StackPanel IsVisible="{Binding !Branded}">
                            <StackPanel Orientation="Horizontal">
                                <Label VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Width="300" Content="{x:Static netCore:Resources.EmulationTypeLabel}" />
                                <ComboBox HorizontalAlignment="Stretch" Width="200"
                                          SelectedItem="{Binding EmulationType}"
                                          ItemTemplate="{StaticResource EnumToStringTemplate}"
                                          ItemsSource="{Binding EmulationTypes}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" IsVisible="{Binding IsKeyboard}">
                                <Label VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Width="300" Content="{x:Static netCore:Resources.MouseMovementTypeLabel}" />
                                <ComboBox HorizontalAlignment="Stretch" Width="200"
                                          SelectedItem="{Binding MouseMovementType}"
                                          ItemTemplate="{StaticResource EnumToStringTemplate}"
                                          ItemsSource="{Binding MouseMovementTypes}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" IsVisible="{Binding IsController}">
                                <Label VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Width="300" Content="{x:Static netCore:Resources.ControllerTypeLabel}" />
                                <ComboBox HorizontalAlignment="Stretch" Width="200"
                                          SelectedItem="{Binding DeviceControllerType}"
                                          ItemTemplate="{StaticResource EnumToStringTemplate}"
                                          ItemsSource="{Binding DeviceControllerRhythmTypes}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <StackPanel.IsVisible>
                                    <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                        <Binding Path="IsKeyboard" />
                                        <Binding Path="IsFortniteFestival" />
                                    </MultiBinding>
                                </StackPanel.IsVisible>
                                <Label VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Width="300" Content="{x:Static netCore:Resources.RolloverModeLabel}" />
                                <ComboBox HorizontalAlignment="Stretch" Width="200"
                                          SelectedItem="{Binding RolloverMode}"
                                          ItemTemplate="{StaticResource EnumToStringTemplate}"
                                          ItemsSource="{Binding RolloverModes}" />
                            </StackPanel>

                        </StackPanel>
                        <StackPanel Orientation="Horizontal" IsVisible="{Binding IsStandardController}">
                            <Label VerticalAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Width="300" Content="{x:Static netCore:Resources.SwapSwitchFaceButtonLabel}" />
                            <ToggleSwitch HorizontalAlignment="Center" Width="200"
                                          HorizontalContentAlignment="Center"
                                          IsChecked="{Binding SwapSwitchFaceButtons}"
                                          OnContent="{x:Static netCore:Resources.EnabledLabel}"
                                          OffContent="{x:Static netCore:Resources.DisabledLabel}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" IsVisible="{Binding IsStandardController}">
                            <Label VerticalAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Width="300" Content="{x:Static netCore:Resources.WindowsControllerModeLabel}" />
                            <ComboBox HorizontalAlignment="Stretch" Width="200"
                                      SelectedIndex="{Binding XInputOnWindows}">
                                <ComboBoxItem Content="{x:Static netCore:Resources.HIDGameControllerLabel}" />
                                <ComboBoxItem Content="{x:Static netCore:Resources.XInputLabel}" />
                            </ComboBox>

                        </StackPanel>


                        <StackPanel Orientation="Horizontal" IsVisible="{Binding IsRpcs3CompatibleController}">
                            <Label VerticalAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Width="300" Content="{x:Static netCore:Resources.RPCS3CompatLabel}" />
                            <ToggleSwitch HorizontalAlignment="Center" Width="200"
                                          HorizontalContentAlignment="Center"
                                          IsChecked="{Binding Ps3OnRpcs3}"
                                          OnContent="{x:Static netCore:Resources.EnabledLabel}"
                                          OffContent="{x:Static netCore:Resources.DisabledLabel}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" IsVisible="{Binding IsGuitarHeroGuitar}">
                            <Label VerticalAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Width="300" Content="{x:Static netCore:Resources.GuitarTapBarEnabled}" />
                            <ToggleSwitch HorizontalAlignment="Center" Width="200"
                                          HorizontalContentAlignment="Center"
                                          IsChecked="{Binding SliderBar}"
                                          OnContent="{x:Static netCore:Resources.EnabledLabel}"
                                          OffContent="{x:Static netCore:Resources.DisabledLabel}" />
                        </StackPanel>
                    </StackPanel>
                </Expander>
                <Expander HorizontalAlignment="Stretch" Header="{Binding}" IsExpanded="{Binding PollExpanded}">
                    <Expander.HeaderTemplate>
                        <DataTemplate DataType="viewModels:ConfigViewModel">
                            <Panel>
                                <StackPanel Orientation="Horizontal">
                                    <Image Width="75"
                                           Source="avares://SantrollerConfigurator/Assets/Icons/Combined/PollRate.png">
                                    </Image>
                                    <Label VerticalAlignment="Center"
                                           VerticalContentAlignment="Center"
                                           Content="{x:Static netCore:Resources.PollSettingsLabel}" />
                                </StackPanel>
                            </Panel>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <StackPanel>
                        <StackPanel IsVisible="{Binding SupportsDeque}">
                            <StackPanel IsVisible="{Binding IsGuitar}" Orientation="Horizontal">
                                <Label VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Width="300" Content="{x:Static netCore:Resources.QueueBasedInputsLabel}" />
                                <ToggleSwitch HorizontalAlignment="Center"
                                              Width="200"
                                              HorizontalContentAlignment="Center" IsChecked="{Binding Deque}"
                                              OnContent="{x:Static netCore:Resources.EnabledLabel}"
                                              OffContent="{x:Static netCore:Resources.DisabledLabel}" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel IsVisible="{Binding !Deque}" Orientation="Horizontal">
                            <Label VerticalAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Width="300" Content="{Binding PollRateLabel }" />
                            <NumericUpDown FormatString="{}{0:#,0}"
                                           Value="{Binding PollRate}"
                                           Width="200"
                                           Minimum="0"
                                           Maximum="10" HorizontalAlignment="Stretch" />
                        </StackPanel>
                        <StackPanel IsVisible="{Binding Deque}" Orientation="Horizontal">
                            <Label VerticalAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Width="300" Content="{Binding PollRateLabel }" />
                            <NumericUpDown FormatString="{}{0:#,0}"
                                           Value="{Binding PollRate}"
                                           Width="200"
                                           Minimum="1"
                                           Maximum="10" HorizontalAlignment="Stretch" />
                        </StackPanel>
                        <StackPanel IsVisible="{Binding !IsAdvancedMode}">
                            <StackPanel Orientation="Horizontal" IsVisible="{Binding Deque}">
                                <Label VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Width="300" Content="{x:Static netCore:Resources.DebounceLabel}" />
                                <NumericUpDown Value="{Binding DebounceDisplay}"
                                               Minimum="0.5"
                                               Increment="0.1"
                                               Width="200"
                                               Maximum="25" HorizontalAlignment="Stretch" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" IsVisible="{Binding !Deque}">
                                <Label VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Width="300" Content="{x:Static netCore:Resources.DebounceExtraLabel}" />
                                <NumericUpDown FormatString="{}{0:#,0}"
                                               Value="{Binding DebounceDisplay}"
                                               Minimum="0"
                                               Increment="1"
                                               Width="200"
                                               Maximum="250" HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel IsVisible="{Binding IsGuitar}" Orientation="Horizontal">
                            <Label VerticalAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Width="300" Content="{x:Static netCore:Resources.StrumDebounceLabel}" />
                            <NumericUpDown Width="200" FormatString="{}{0:#,0}"
                                           Value="{Binding StrumDebounceDisplay}"
                                           Minimum="0"
                                           Maximum="25" HorizontalAlignment="Stretch" />
                        </StackPanel>
                        <StackPanel IsVisible="{Binding IsGuitar}" Orientation="Horizontal">
                            <Label VerticalAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Width="300"
                                   Content="{x:Static netCore:Resources.CombinedStrumDebounceLabel}" />
                            <ToggleSwitch HorizontalAlignment="Right"
                                          HorizontalContentAlignment="Right"
                                          IsChecked="{Binding CombinedStrumDebounce}"
                                          OnContent="{x:Static netCore:Resources.StrumCombinedLabel}"
                                          OffContent="{x:Static netCore:Resources.StrumIndividualLabel}" />
                        </StackPanel>
                    </StackPanel>
                </Expander>
                <Expander HorizontalAlignment="Stretch" Header="{Binding}" IsVisible="{Binding !Branded}"
                          IsExpanded="{Binding PresetsExpanded}">
                    <Expander.HeaderTemplate>
                        <DataTemplate DataType="viewModels:ConfigViewModel">
                            <Panel>
                                <StackPanel Orientation="Horizontal">
                                    <Image Width="75"
                                           Source="avares://SantrollerConfigurator/Assets/Icons/Combined/Presets.png">
                                    </Image>
                                    <Label VerticalAlignment="Center"
                                           VerticalContentAlignment="Center"
                                           Content="{x:Static netCore:Resources.PresetLabel}" />
                                </StackPanel>
                            </Panel>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label VerticalAlignment="Center" Width="300"
                                   Content="{x:Static netCore:Resources.ImportConfigLabel}" />
                            <Button Command="{Binding LoadConfigCommand}"
                                    HorizontalAlignment="Stretch" Width="300" HorizontalContentAlignment="Center"
                                    Content="{x:Static netCore:Resources.ImportConfigLabel}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label VerticalAlignment="Center" Width="300"
                                   Content="{x:Static netCore:Resources.ExportConfigLabel}" />
                            <Button Command="{Binding SaveConfigCommand}"
                                    HorizontalAlignment="Stretch" Width="300" HorizontalContentAlignment="Center"
                                    Content="{x:Static netCore:Resources.ExportConfigLabel}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label VerticalAlignment="Center" Width="300"
                                   Content="{x:Static netCore:Resources.SavePresetLabel}" />
                            <TextBox Width="300" Text="{Binding PresetName}"></TextBox>
                            <Button Command="{Binding SavePresetCommand}"
                                    IsEnabled="{Binding PresetName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                    HorizontalAlignment="Stretch" Width="300" HorizontalContentAlignment="Center"
                                    Content="{Binding SavePresetLabel}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label VerticalAlignment="Center" Width="300"
                                   Content="{x:Static netCore:Resources.PresetLabel}" />
                            <ComboBox Width="300"
                                      IsEnabled="{Binding Presets.Count}"
                                      SelectedItem="{Binding CurrentPreset}"
                                      ItemsSource="{Binding Presets}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Item1, Mode=OneWay}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label VerticalAlignment="Center" Width="300"
                                   Content="{x:Static netCore:Resources.LoadPresetSimple}" />
                            <Button Command="{Binding LoadPresetCommand}"
                                    IsEnabled="{Binding Presets.Count}"
                                    HorizontalAlignment="Stretch" Width="300" HorizontalContentAlignment="Center"
                                    Content="{Binding LoadPresetLabel}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label VerticalAlignment="Center" Width="300"
                                   Content="{x:Static netCore:Resources.DeletePresetLabel}" />
                            <Button Command="{Binding DeletePresetCommand}"
                                    IsEnabled="{Binding Presets.Count}"
                                    HorizontalAlignment="Stretch" Width="300" HorizontalContentAlignment="Center"
                                    Content="{Binding DeletePresetLabel}" />
                        </StackPanel>
                    </StackPanel>
                </Expander>
                <Expander HorizontalAlignment="Stretch" Header="{Binding}"
                          IsExpanded="{Binding LedConfigExpanded}">

                    <Expander.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.Or}">
                            <Binding Path="!Branded" />
                            <Binding
                                Path="IsApa102" />
                            <Binding Path="IsApa102Peripheral" />
                        </MultiBinding>
                    </Expander.IsVisible>
                    <Expander.HeaderTemplate>
                        <DataTemplate DataType="viewModels:ConfigViewModel">
                            <Panel>
                                <StackPanel Orientation="Horizontal">
                                    <Image Width="75"
                                           Source="avares://SantrollerConfigurator/Assets/Icons/Combined/Led.png">
                                    </Image>
                                    <Label VerticalAlignment="Center"
                                           VerticalContentAlignment="Center"
                                           Content="{x:Static netCore:Resources.LEDSettingsLabel}" />
                                </StackPanel>
                                <Label Foreground="Red" Margin="45 0 0 0"
                                       Content="{Binding LedErrorText}"
                                       VerticalAlignment="Bottom"
                                       HorizontalAlignment="Center"
                                       HorizontalContentAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       IsVisible="{Binding LedErrorText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                            </Panel>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <StackPanel>
                        <StackPanel IsVisible="{Binding !Branded}">
                            <StackPanel Orientation="Horizontal" IsVisible="{Binding !Branded}">
                                <Label VerticalAlignment="Center" Width="300"
                                       Content="{x:Static netCore:Resources.LEDTypeLabel}" />
                                <ComboBox Width="200"
                                          SelectedItem="{Binding LedType}"
                                          ItemTemplate="{StaticResource EnumToStringTemplate}"
                                          ItemsSource="{Binding LedTypes}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" IsVisible="{Binding IsIndexedLed}">
                                <Label VerticalAlignment="Center" Width="300"
                                       Content="{x:Static netCore:Resources.LEDTypeCountLabel}" />
                                <NumericUpDown Width="200" FormatString="{}{0:#,0}"
                                               Value="{Binding LedCount}"
                                               Minimum="1"
                                               Maximum="180" />
                            </StackPanel>


                            <StackPanel Orientation="Horizontal">
                                <StackPanel.IsVisible>
                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                        <Binding Path="BindableSpi" />
                                        <Binding Path="IsIndexedLed" />
                                        <Binding Path="!IsWs2812" />
                                    </MultiBinding>
                                </StackPanel.IsVisible>
                                <Label VerticalAlignment="Center" Width="300" IsVisible="{Binding IsApa102}"
                                       Content="{x:Static netCore:Resources.APA102SCKLabel}" />
                                <Label VerticalAlignment="Center" Width="300" IsVisible="{Binding IsStp16}"
                                       Content="{x:Static netCore:Resources.STP16CPC26SCKLabel}" />
                                <ComboBox Width="200"
                                          SelectedItem="{Binding LedSck}"
                                          ItemsSource="{Binding AvailableApaSckPins}"
                                          DropDownOpened="ReloadPinTemplates"
                                          ItemTemplate="{StaticResource PinToStringTemplateSpi}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <StackPanel.IsVisible>
                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                        <Binding Path="BindableSpi" />
                                        <Binding Path="IsIndexedLed" />
                                    </MultiBinding>
                                </StackPanel.IsVisible>
                                <Label IsVisible="{Binding IsWs2812}" VerticalAlignment="Center" Width="300"
                                       Content="{x:Static netCore:Resources.WS2812MOSILabel}" />
                                <Label IsVisible="{Binding IsApa102}" VerticalAlignment="Center" Width="300"
                                       Content="{x:Static netCore:Resources.APA102MOSILabel}" />
                                <Label VerticalAlignment="Center" Width="300" IsVisible="{Binding IsStp16}"
                                       Content="{x:Static netCore:Resources.STP16CPC26MOSILabel}" />
                                <ComboBox Width="200"
                                          SelectedItem="{Binding LedMosi}"
                                          ItemsSource="{Binding AvailableApaMosiPins}"
                                          DropDownOpened="ReloadPinTemplates"
                                          ItemTemplate="{StaticResource PinToStringTemplateSpi}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" IsVisible="{Binding IsStp16}">
                                <Label VerticalAlignment="Center" Width="300"
                                       Content="{x:Static netCore:Resources.STP16CPC26OELabel}" />
                                <ComboBox Width="200"
                                          DropDownOpened="ReloadPinTemplates"
                                          SelectedItem="{Binding Stp16Oe}"
                                          ItemsSource="{Binding AvailablePinsDigital}"
                                          ItemTemplate="{StaticResource PinToStringTemplate}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" IsVisible="{Binding IsStp16}">
                                <Label VerticalAlignment="Center" Width="300"
                                       Content="{x:Static netCore:Resources.STP16CPC26LELabel}" />
                                <ComboBox Width="200"
                                          DropDownOpened="ReloadPinTemplates"
                                          SelectedItem="{Binding Stp16Le}"
                                          ItemsSource="{Binding AvailablePinsDigital}"
                                          ItemTemplate="{StaticResource PinToStringTemplate}" />
                            </StackPanel>
                            <StackPanel IsVisible="{Binding HasPeripheral}" Orientation="Horizontal">
                                <Label VerticalAlignment="Center" Width="300"
                                       Content="{x:Static netCore:Resources.LEDTypePeripheralLabel}" />

                                <ComboBox VerticalAlignment="Center" Width="200"
                                          SelectedItem="{Binding LedTypePeripheral}"
                                          ItemTemplate="{StaticResource EnumToStringTemplate}"
                                          ItemsSource="{Binding LedTypes}" />
                            </StackPanel>
                            <StackPanel IsVisible="{Binding IsIndexedLedPeripheral}" Orientation="Horizontal">
                                <Label VerticalAlignment="Center" Width="300"
                                       Content="{x:Static netCore:Resources.LEDTypePeripheralCountLabel}" />
                                <NumericUpDown VerticalAlignment="Center" Width="200" FormatString="{}{0:#,0}"
                                               Value="{Binding LedCountPeripheral}"
                                               Minimum="1"
                                               Maximum="180" HorizontalAlignment="Stretch" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <StackPanel.IsVisible>
                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                        <Binding Path="BindableSpi" />
                                        <Binding Path="IsIndexedLedPeripheral" />
                                    </MultiBinding>
                                </StackPanel.IsVisible>
                                <Label IsVisible="{Binding IsApa102Peripheral}" VerticalAlignment="Center" Width="300"
                                       Content="{x:Static netCore:Resources.APA102SCKPeripheralLabel}" />
                                <Label IsVisible="{Binding IsStp16Peripheral}" VerticalAlignment="Center" Width="300"
                                       Content="{x:Static netCore:Resources.STP16CPC26SCKPeripheralLabel}" />
                                <ComboBox VerticalAlignment="Center" Width="200"
                                          SelectedItem="{Binding LedSckPeripheral}"
                                          ItemsSource="{Binding AvailableApaSckPins}"
                                          DropDownOpened="ReloadPinTemplates"
                                          ItemTemplate="{StaticResource PinToStringTemplatePeripheralSpi}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <StackPanel.IsVisible>
                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                        <Binding Path="BindableSpi" />
                                        <Binding Path="IsIndexedLedPeripheral" />
                                    </MultiBinding>
                                </StackPanel.IsVisible>
                                <Label IsVisible="{Binding IsApa102Peripheral}" VerticalAlignment="Center" Width="300"
                                       Content="{x:Static netCore:Resources.APA102MOSIPeripheralLabel}" />
                                <Label IsVisible="{Binding IsStp16Peripheral}" VerticalAlignment="Center" Width="300"
                                       Content="{x:Static netCore:Resources.STP16CPC26MOSIPeripheralLabel}" />
                                <ComboBox VerticalAlignment="Center" Width="200"
                                          SelectedItem="{Binding LedMosiPeripheral}"
                                          ItemsSource="{Binding AvailableApaMosiPins}"
                                          DropDownOpened="ReloadPinTemplates"
                                          ItemTemplate="{StaticResource PinToStringTemplatePeripheralSpi}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" IsVisible="{Binding IsStp16Peripheral}">
                                <Label VerticalAlignment="Center" Width="300"
                                       Content="{x:Static netCore:Resources.STP16CPC26OEPeripheralLabel}" />
                                <ComboBox Width="200"
                                          DropDownOpened="ReloadPinTemplates"
                                          SelectedItem="{Binding Stp16OePeripheral}"
                                          ItemsSource="{Binding AvailablePinsDigital}"
                                          ItemTemplate="{StaticResource PinToStringTemplate}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" IsVisible="{Binding IsStp16Peripheral}">
                                <Label VerticalAlignment="Center" Width="300"
                                       Content="{x:Static netCore:Resources.STP16CPC26LEPeripheralLabel}" />
                                <ComboBox Width="200"
                                          SelectedItem="{Binding Stp16LePeripheral}"
                                          ItemsSource="{Binding AvailablePinsDigital}"
                                          DropDownOpened="ReloadPinTemplates"
                                          ItemTemplate="{StaticResource PinToStringTemplate}" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel>
                            <StackPanel.IsVisible>
                                <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                    <Binding
                                        Path="IsApa102" />
                                    <Binding Path="IsApa102Peripheral" />
                                </MultiBinding>
                            </StackPanel.IsVisible>
                            <StackPanel Orientation="Horizontal" IsVisible="{Binding IsApa102}">
                                <Label VerticalAlignment="Center" Width="300"
                                       Content="{x:Static netCore:Resources.LedBrightnessOnLabel}" />
                                <NumericUpDown Height="30" Width="200" FormatString="{}{0:#,0}"
                                               Value="{Binding LedBrightnessOn}"
                                               Minimum="1"
                                               Maximum="31" />
                                <Slider Value="{Binding LedBrightnessOn}"
                                        Minimum="1"
                                        Maximum="31"
                                        IsSnapToTickEnabled="True"
                                        TickFrequency="1" Width="200" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" IsVisible="{Binding IsApa102}">
                                <Label VerticalAlignment="Center" Width="300"
                                       Content="{x:Static netCore:Resources.LedBrightnessOffLabel}" />
                                <NumericUpDown Height="30" Width="200" FormatString="{}{0:#,0}"
                                               Value="{Binding LedBrightnessOff}"
                                               Minimum="1"
                                               Maximum="31" />
                                <Slider Value="{Binding LedBrightnessOff}"
                                        Minimum="1"
                                        Maximum="31"
                                        IsSnapToTickEnabled="True"
                                        TickFrequency="1" Width="200" />
                            </StackPanel>
                            <StackPanel IsVisible="{Binding Builder}" Orientation="Horizontal">
                                <Label VerticalAlignment="Center" Width="300"
                                       Content="{x:Static netCore:Resources.Apa1022020Label}" />
                                <ToggleSwitch HorizontalAlignment="Center" Width="200"
                                              HorizontalContentAlignment="Center"
                                              IsChecked="{Binding Apa102IsFullSize}"
                                              OnContent="{x:Static netCore:Resources.EnabledLabel}"
                                              OffContent="{x:Static netCore:Resources.DisabledLabel}" />
                            </StackPanel>
                            <Label Foreground="Red" Content="{x:Static netCore:Resources.BrightnessNote1}">
                                <Label.IsVisible>
                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                        <Binding
                                            Path="!Branded" />
                                        <Binding Path="!Apa102IsFullSize" />
                                    </MultiBinding>
                                </Label.IsVisible>
                            </Label>
                            <Label Foreground="Red" Content="{x:Static netCore:Resources.BrightnessNote2}"
                                   IsVisible="{Binding !Apa102IsFullSize}" />
                            <Label Foreground="Red" Content="{x:Static netCore:Resources.BrightnessNote3}"
                                   IsVisible="{Binding !Apa102IsFullSize}" />
                        </StackPanel>
                    </StackPanel>
                </Expander>
                <Expander IsVisible="{Binding IsBluetoothTx}" HorizontalAlignment="Stretch" Header="{Binding}"
                          IsExpanded="{Binding BluetoothConfigExpanded}">
                    <Expander.HeaderTemplate>
                        <DataTemplate DataType="viewModels:ConfigViewModel">
                            <Panel HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Image Width="75"
                                           Source="avares://SantrollerConfigurator/Assets/Icons/Combined/Bluetooth.png" />
                                    <Label VerticalAlignment="Center"
                                           VerticalContentAlignment="Center"
                                           Content="{x:Static netCore:Resources.BluetoothTransmitterSettingsLabel}" />
                                </StackPanel>
                                <CheckBox IsChecked="{Binding Connected}" Margin="45 0 0 0"
                                          HorizontalAlignment="Center"
                                          IsEnabled="False"
                                          Content="{x:Static netCore:Resources.ConnectedToReceiverLabel}" />
                            </Panel>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label VerticalAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Width="300" Content="{x:Static netCore:Resources.LocalAddressLabel}" />
                            <Label VerticalAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Width="200" Content="{Binding LocalAddress}" />
                        </StackPanel>
                    </StackPanel>
                </Expander>
                <Expander HorizontalAlignment="Stretch" Header="{Binding}"
                          IsExpanded="{Binding PeripheralExpanded}">
                    <Expander.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="IsPico" />
                            <Binding Path="!Branded" />
                        </MultiBinding>
                    </Expander.IsVisible>
                    <Expander.HeaderTemplate>
                        <DataTemplate DataType="viewModels:ConfigViewModel">
                            <Panel>
                                <StackPanel Orientation="Horizontal">
                                    <Image Width="75"
                                           Source="avares://SantrollerConfigurator/Assets/Icons/Combined/Peripheral.png">
                                    </Image>
                                    <Label VerticalAlignment="Center"
                                           VerticalContentAlignment="Center"
                                           Content="{x:Static netCore:Resources.PeripheralSettingsLabel}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="45 0 0 0" HorizontalAlignment="Center"
                                            IsVisible="{Binding HasPeripheral}">
                                    <CheckBox IsChecked="{Binding PeripheralConnected}" VerticalAlignment="Center"
                                              IsEnabled="False"
                                              Content="{x:Static netCore:Resources.DetectedLabel}" />
                                </StackPanel>
                                <Label Foreground="Red" Margin="45 0 0 0"
                                       Content="{Binding PeripheralErrorText}"
                                       VerticalAlignment="Bottom"
                                       HorizontalAlignment="Center"
                                       HorizontalContentAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       IsVisible="{Binding PeripheralErrorText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                            </Panel>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <StackPanel>
                        <StackPanel IsVisible="{Binding IsPico}" Orientation="Horizontal">
                            <Label VerticalAlignment="Center" Width="300"
                                   Content="{x:Static netCore:Resources.HasPeripheralLabel}" />
                            <ToggleSwitch HorizontalAlignment="Center" Width="200"
                                          HorizontalContentAlignment="Center" IsChecked="{Binding HasPeripheral}"
                                          OnContent="{x:Static netCore:Resources.EnabledLabel}"
                                          OffContent="{x:Static netCore:Resources.DisabledLabel}" />
                        </StackPanel>

                        <StackPanel IsVisible="{Binding HasPeripheral}">
                            <StackPanel IsVisible="{Binding BindableTwi}" Orientation="Horizontal">
                                <Label VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Width="300" Content="{x:Static netCore:Resources.SclLabel}" />
                                <ComboBox VerticalAlignment="Center"
                                          SelectedItem="{Binding PeripheralScl}"
                                          ItemsSource="{Binding AvailableSclPins}"
                                          DropDownOpened="ReloadPinTemplates"
                                          ItemTemplate="{StaticResource PinToStringTemplateTwi}"
                                          Width="200" />
                            </StackPanel>
                            <StackPanel IsVisible="{Binding BindableTwi}" Orientation="Horizontal">
                                <Label VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Width="300" Content="{x:Static netCore:Resources.SdaLabel}" />
                                <ComboBox VerticalAlignment="Center"
                                          SelectedItem="{Binding PeripheralSda}"
                                          ItemsSource="{Binding AvailableSdaPins}"
                                          DropDownOpened="ReloadPinTemplates"
                                          ItemTemplate="{StaticResource PinToStringTemplateTwi}"
                                          Width="200" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Expander>
                <Expander HorizontalAlignment="Stretch" Header="{Binding}"
                          IsExpanded="{Binding Mpr121Expanded}" IsVisible="{Binding !Branded}">
                    <Expander.HeaderTemplate>
                        <DataTemplate DataType="viewModels:ConfigViewModel">
                            <Panel>
                                <StackPanel Orientation="Horizontal">
                                    <Image Width="75"
                                           Source="avares://SantrollerConfigurator/Assets/Icons/Combined/Peripheral.png">
                                    </Image>
                                    <Label VerticalAlignment="Center"
                                           VerticalContentAlignment="Center"
                                           Content="{x:Static netCore:Resources.Mpr121SettingsLabel}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="45 0 0 0" HorizontalAlignment="Center"
                                            IsVisible="{Binding HasMpr121}">
                                    <CheckBox IsChecked="{Binding Mpr121Connected}" VerticalAlignment="Center"
                                              IsEnabled="False"
                                              Content="{x:Static netCore:Resources.DetectedLabel}" />
                                </StackPanel>
                                <Label Foreground="Red" Margin="45 0 0 0"
                                       Content="{Binding Mpr121ErrorText}"
                                       VerticalAlignment="Bottom"
                                       HorizontalAlignment="Center"
                                       HorizontalContentAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       IsVisible="{Binding Mpr121ErrorText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                            </Panel>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label VerticalAlignment="Center" Width="300"
                                   Content="{x:Static netCore:Resources.HasMpr121Label}" />
                            <ToggleSwitch HorizontalAlignment="Center" Width="200"
                                          HorizontalContentAlignment="Center" IsChecked="{Binding HasMpr121}"
                                          OnContent="{x:Static netCore:Resources.EnabledLabel}"
                                          OffContent="{x:Static netCore:Resources.DisabledLabel}" />
                        </StackPanel>

                        <StackPanel IsVisible="{Binding HasMpr121}">
                            <StackPanel IsVisible="{Binding BindableTwi}" Orientation="Horizontal">
                                <Label VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Width="300" Content="{x:Static netCore:Resources.SclLabel}" />
                                <ComboBox VerticalAlignment="Center"
                                          SelectedItem="{Binding Mpr121Scl}"
                                          ItemsSource="{Binding AvailableSclPins}"
                                          DropDownOpened="ReloadPinTemplates"
                                          ItemTemplate="{StaticResource PinToStringTemplateTwi}"
                                          Width="200" />
                            </StackPanel>
                            <StackPanel IsVisible="{Binding BindableTwi}" Orientation="Horizontal">
                                <Label VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Width="300" Content="{x:Static netCore:Resources.SdaLabel}" />
                                <ComboBox VerticalAlignment="Center"
                                          SelectedItem="{Binding Mpr121Sda}"
                                          ItemsSource="{Binding AvailableSdaPins}"
                                          DropDownOpened="ReloadPinTemplates"
                                          ItemTemplate="{StaticResource PinToStringTemplateTwi}"
                                          Width="200" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Label VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Width="300" Content="{x:Static netCore:Resources.Mpr121CapacativeCountLabel}" />

                                <NumericUpDown VerticalAlignment="Center" Width="200" FormatString="{}{0:#,0}"
                                               Value="{Binding Mpr121CapacitiveCount}"
                                               Minimum="0"
                                               Maximum="12" HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Expander>
                <Expander HorizontalAlignment="Stretch" Header="{Binding}"
                          IsExpanded="{Binding Max170XExpanded}">
                    <Expander.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="IsBluetoothTx" />
                            <Binding Path="!Branded" />
                        </MultiBinding>
                    </Expander.IsVisible>
                    <Expander.HeaderTemplate>
                        <DataTemplate DataType="viewModels:ConfigViewModel">
                            <Panel>
                                <StackPanel Orientation="Horizontal">
                                    <Image Width="75"
                                           Source="avares://SantrollerConfigurator/Assets/Icons/Combined/Battery.png">
                                    </Image>
                                    <Label VerticalAlignment="Center"
                                           VerticalContentAlignment="Center"
                                           Content="{x:Static netCore:Resources.MAX1704xSettingsLabel}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="45 0 0 0" HorizontalAlignment="Center"
                                            IsVisible="{Binding HasMax1704X}">
                                    <CheckBox IsChecked="{Binding Max1704XConnected}" VerticalAlignment="Center"
                                              IsEnabled="False"
                                              Content="{x:Static netCore:Resources.DetectedLabel}" />
                                    <Label VerticalAlignment="Center"
                                           VerticalContentAlignment="Center"
                                           Content="{x:Static netCore:Resources.Max1704xStatusLabel}" />
                                    <Label VerticalAlignment="Center"
                                           VerticalContentAlignment="Center"
                                           Content="{Binding Max1704XStatus}" />
                                </StackPanel>
                                <Label Foreground="Red" Margin="45 0 0 0"
                                       Content="{Binding Max170XErrorText}"
                                       VerticalAlignment="Bottom"
                                       HorizontalAlignment="Center"
                                       HorizontalContentAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       IsVisible="{Binding Max170XErrorText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                            </Panel>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <StackPanel>
                        <StackPanel IsVisible="{Binding IsPico}" Orientation="Horizontal">
                            <Label VerticalAlignment="Center" Width="300"
                                   Content="{x:Static netCore:Resources.HasMax1704xLabel}" />
                            <ToggleSwitch HorizontalAlignment="Center" Width="200"
                                          HorizontalContentAlignment="Center" IsChecked="{Binding HasMax1704X}"
                                          OnContent="{x:Static netCore:Resources.EnabledLabel}"
                                          OffContent="{x:Static netCore:Resources.DisabledLabel}" />
                        </StackPanel>

                        <StackPanel IsVisible="{Binding HasMax1704X}">
                            <StackPanel IsVisible="{Binding BindableTwi}" Orientation="Horizontal">
                                <Label VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Width="300" Content="{x:Static netCore:Resources.SclLabel}" />
                                <ComboBox VerticalAlignment="Center"
                                          SelectedItem="{Binding Max1704XScl}"
                                          ItemsSource="{Binding AvailableSclPins}"
                                          DropDownOpened="ReloadPinTemplates"
                                          ItemTemplate="{StaticResource PinToStringTemplateTwi}"
                                          Width="200" />
                            </StackPanel>
                            <StackPanel IsVisible="{Binding BindableTwi}" Orientation="Horizontal">
                                <Label VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Width="300" Content="{x:Static netCore:Resources.SdaLabel}" />
                                <ComboBox VerticalAlignment="Center"
                                          SelectedItem="{Binding Max1704XSda}"
                                          ItemsSource="{Binding AvailableSdaPins}"
                                          DropDownOpened="ReloadPinTemplates"
                                          ItemTemplate="{StaticResource PinToStringTemplateTwi}"
                                          Width="200" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Expander>
                <ItemsControl ItemsSource="{Binding Outputs}" x:Name="OutputsContainer">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="output:Output">
                            <StackPanel>
                                <Expander IsVisible="{Binding !IsEmpty}" HorizontalAlignment="Stretch"
                                          Header="{Binding}" IsExpanded="{Binding Expanded}">
                                    <Expander.HeaderTemplate>
                                        <DataTemplate DataType="output:Output">
                                            <Panel>
                                                <StackPanel Orientation="Horizontal">
                                                    <ContentControl
                                                        ContentTemplate="{StaticResource ImageOutputTemplate}"
                                                        Content="{Binding }" />
                                                    <Label VerticalAlignment="Center"
                                                           VerticalContentAlignment="Center"
                                                           Content="{Binding LocalisedName}" />
                                                </StackPanel>
                                                <ContentControl Content="{Binding}" Margin="45 0 0 0"
                                                                HorizontalAlignment="Center"
                                                                ContentTemplate="{StaticResource OutputHeaderTemplates}" />

                                                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal"
                                                            IsVisible="{Binding !$parent[views:ConfigView].((viewModels:ConfigViewModel)DataContext).Branded}">
                                                    <Button
                                                        Command="{Binding RemoveCommand}"
                                                        Content="{x:Static netCore:Resources.RemoveLabel}" />
                                                    <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                                        <Button
                                                            Command="{Binding MoveUp}">
                                                            <Path HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  Stretch="None"
                                                                  Stroke="White"
                                                                  Data="M 0 7 L 7 0 L 14 7"
                                                                  StrokeThickness="1" />
                                                        </Button>
                                                        <Button
                                                            Command="{Binding MoveDown}">
                                                            <Path HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  Stretch="None"
                                                                  Stroke="White"
                                                                  Data="M 0 0 L 7 7 L 14 0"
                                                                  StrokeThickness="1" />
                                                        </Button>
                                                    </StackPanel>
                                                </StackPanel>
                                                <Label Foreground="Red" Margin="45 0 0 0"
                                                       Content="{Binding ErrorText}"
                                                       VerticalAlignment="Bottom"
                                                       HorizontalAlignment="Center"
                                                       HorizontalContentAlignment="Center"
                                                       VerticalContentAlignment="Center"
                                                       IsVisible="{Binding ErrorText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                            </Panel>
                                        </DataTemplate>
                                    </Expander.HeaderTemplate>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" IsVisible="{Binding IsKeyboard}">
                                            <Label VerticalAlignment="Center"
                                                   VerticalContentAlignment="Center"
                                                   Width="300" Content="{x:Static netCore:Resources.OutputTypeLabel}" />
                                            <ComboBox VerticalAlignment="Center"
                                                      SelectedItem="{Binding KeyOrMouse}"
                                                      ItemsSource="{Binding KeyOrMouseInputs}"
                                                      ItemTemplate="{StaticResource EnumToStringTemplate}" />
                                            <Button Command="{Binding FindAndAssignCommand}"
                                                    IsEnabled="{Binding ConfigurableInput}"
                                                    Content="{Binding ButtonText}" />
                                        </StackPanel>
                                        <ContentControl ContentTemplate="{StaticResource OutputSelectionTemplate}"
                                                        Content="{Binding}" />

                                        <StackPanel Orientation="Horizontal">
                                            <StackPanel.IsVisible>
                                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                    <Binding
                                                        Path="!$parent[views:ConfigView].((viewModels:ConfigViewModel)DataContext).Branded" />
                                                    <Binding Path="!IsCombined" />
                                                    <Binding Path="ConfigurableInput" />
                                                </MultiBinding>
                                            </StackPanel.IsVisible>
                                            <Label VerticalAlignment="Center"
                                                   VerticalContentAlignment="Center"
                                                   Width="300" Content="{x:Static netCore:Resources.InputTypeLabel}" />
                                            <ComboBox VerticalAlignment="Center"
                                                      SelectedItem="{Binding SelectedInputType}"
                                                      ItemsSource="{Binding InputTypes}"
                                                      ItemTemplate="{StaticResource ImageWithTextTemplateGeneric}" />
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal">
                                            <StackPanel.IsVisible>
                                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                    <Binding Path="ConfigurableInput" />
                                                    <Binding
                                                        Path="!$parent[views:ConfigView].((viewModels:ConfigViewModel)DataContext).Branded" />
                                                    <Binding Path="!IsCombined" />
                                                    <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                                        <Binding Path="IsWii" />
                                                        <Binding Path="IsDj" />
                                                        <Binding Path="IsPs2" />
                                                        <Binding Path="IsGh5OrClone" />
                                                        <Binding Path="IsWt" />
                                                        <Binding Path="IsUsb" />
                                                        <Binding Path="IsAdxl" />
                                                    </MultiBinding>
                                                </MultiBinding>
                                            </StackPanel.IsVisible>
                                            <Label VerticalAlignment="Center"
                                                   VerticalContentAlignment="Center"
                                                   Width="300" Content="{x:Static netCore:Resources.InputLabel}" />
                                            <ComboBox VerticalAlignment="Center"
                                                      IsVisible="{Binding IsWii}"
                                                      SelectedItem="{Binding WiiInputType}"
                                                      ItemsSource="{Binding WiiInputTypes}"
                                                      ItemTemplate="{StaticResource ImageWithTextTemplate}" />
                                            <ComboBox VerticalAlignment="Center"
                                                      IsVisible="{Binding IsAdxl}"
                                                      SelectedItem="{Binding AdxlInputType}"
                                                      ItemsSource="{Binding AdxlInputTypes}"
                                                      ItemTemplate="{StaticResource ImageWithTextTemplate}" />
                                            <ComboBox VerticalAlignment="Center"
                                                      IsVisible="{Binding IsUsb}"
                                                      SelectedItem="{Binding UsbInputType}"
                                                      ItemsSource="{Binding UsbInputTypes}"
                                                      ItemTemplate="{StaticResource ImageWithTextTemplate}" />
                                            <ComboBox VerticalAlignment="Center"
                                                      IsVisible="{Binding IsDj}"
                                                      SelectedItem="{Binding DjInputType}"
                                                      ItemsSource="{Binding DjInputTypes}"
                                                      ItemTemplate="{StaticResource ImageWithTextTemplate}" />
                                            <ComboBox VerticalAlignment="Center"
                                                      IsVisible="{Binding IsPs2}"
                                                      SelectedItem="{Binding Ps2InputType}"
                                                      ItemsSource="{Binding Ps2InputTypes}"
                                                      ItemTemplate="{StaticResource ImageWithTextTemplate}" />
                                            <ComboBox VerticalAlignment="Center"
                                                      IsVisible="{Binding IsGh5OrClone}"
                                                      SelectedItem="{Binding Gh5NeckInputType}"
                                                      ItemsSource="{Binding Gh5NeckInputTypes}"
                                                      ItemTemplate="{StaticResource ImageWithTextTemplate}" />
                                            <ComboBox VerticalAlignment="Center"
                                                      IsVisible="{Binding IsWt}"
                                                      SelectedItem="{Binding GhWtInputType}"
                                                      ItemsSource="{Binding GhWtInputTypes}"
                                                      ItemTemplate="{StaticResource ImageWithTextTemplate}" />
                                        </StackPanel>
                                        <ContentControl ContentTemplate="{StaticResource OutputTemplate}"
                                                        Content="{Binding}" />

                                        <StackPanel Orientation="Horizontal" IsVisible="{Binding IsUsbHostKeyboard}">
                                            <Label VerticalAlignment="Center"
                                                   VerticalContentAlignment="Center"
                                                   Width="300" Content="{x:Static netCore:Resources.KeyTypeLabel}" />
                                            <ComboBox VerticalAlignment="Center"
                                                      SelectedItem="{Binding UsbHostKey}"
                                                      ItemsSource="{Binding KeyboardButtons}"
                                                      ItemTemplate="{StaticResource EnumToStringTemplate}" />
                                            <Button Command="{Binding FindAndAssignUsbHostKeyCommand}"
                                                    IsEnabled="{Binding ConfigurableInput}"
                                                    Content="{Binding ButtonTextUsbHostKey}" />
                                        </StackPanel>


                                        <StackPanel Orientation="Horizontal" IsVisible="{Binding IsUsbHostMouseAxis}">
                                            <Label VerticalAlignment="Center"
                                                   VerticalContentAlignment="Center"
                                                   Width="300"
                                                   Content="{x:Static netCore:Resources.MouseAxisTypeLabel}" />
                                            <ComboBox VerticalAlignment="Center"
                                                      SelectedItem="{Binding UsbHostKeyMouseAxisType}"
                                                      ItemsSource="{Binding MouseAxisTypes}"
                                                      ItemTemplate="{StaticResource EnumToStringTemplate}" />
                                            <Button Command="{Binding FindAndAssignUsbHostMouseAxisCommand}"
                                                    IsEnabled="{Binding ConfigurableInput}"
                                                    Content="{Binding ButtonTextUsbHostKey}" />
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" IsVisible="{Binding IsUsbHostMouseButton}">
                                            <Label VerticalAlignment="Center"
                                                   VerticalContentAlignment="Center"
                                                   Width="300"
                                                   Content="{x:Static netCore:Resources.MouseButtonTypeLabel}" />
                                            <ComboBox VerticalAlignment="Center"
                                                      SelectedItem="{Binding UsbHostKeyMouseButtonType}"
                                                      ItemsSource="{Binding MouseButtonTypes}"
                                                      ItemTemplate="{StaticResource EnumToStringTemplate}" />
                                            <Button Command="{Binding FindAndAssignUsbHostMouseButtonCommand}"
                                                    IsEnabled="{Binding ConfigurableInput}"
                                                    Content="{Binding ButtonTextUsbHostKey}" />
                                        </StackPanel>
                                        <ItemsControl IsVisible="{Binding IsCombined}"
                                                      HorizontalAlignment="Stretch"
                                                      IsEnabled="{Binding IsCombined}"
                                                      ItemsSource="{Binding DigitalOutputs}"
                                                      ItemTemplate="{StaticResource CombinedOutputTemplate}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                        <ItemsControl IsVisible="{Binding IsCombined}"
                                                      HorizontalAlignment="Stretch"
                                                      IsEnabled="{Binding IsCombined}"
                                                      ItemsSource="{Binding AnalogOutputs}"
                                                      ItemTemplate="{StaticResource CombinedOutputTemplate}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </StackPanel>
                                </Expander>
                                <ContentControl IsVisible="{Binding IsEmpty}"
                                                ContentTemplate="{StaticResource EmptySelector}"
                                                Content="{Binding}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Expander HorizontalAlignment="Stretch" Header="{Binding}"
                          IsExpanded="{Binding TestExpanded}" IsVisible="{Binding Branded}">
                    <Expander.HeaderTemplate>
                        <DataTemplate DataType="viewModels:ConfigViewModel">
                            <Panel>
                                <StackPanel Orientation="Horizontal">
                                    <Image Width="75"
                                           Source="avares://SantrollerConfigurator/Assets/Icons/Generic.png">
                                    </Image>
                                    <Label VerticalAlignment="Center"
                                           VerticalContentAlignment="Center"
                                           Content="{x:Static netCore:Resources.ButtonTestLabel}" />
                                </StackPanel>
                            </Panel>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <StackPanel>
                        <ItemsControl HorizontalAlignment="Stretch"
                                      ItemsSource="{Binding DigitalOutputs}"
                                      ItemTemplate="{StaticResource DigitalOutputTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </Panel>
</UserControl>