            <DataTemplate DataType="{x:Type inputs:Mpr121Input}">
                <StackPanel Orientation="Vertical">
                    <StackPanel IsVisible="{Binding !Model.Branded}" Orientation="Horizontal">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="300" Content="{x:Static netCore:Resources.Mpr121ChannelLabel}" />
                        <ComboBox VerticalAlignment="Center"
                                  SelectedItem="{Binding Input}"
                                  ItemsSource="{Binding AvailableInputs}"
                                  DropDownOpened="ReloadPinTemplates"
                                  Width="200">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource Mpr121ChannelToStringConverter }">
                                                <Binding />
                                                <Binding Path="$parent[UserControl].DataContext" />
                                                <Binding
                                                    Path="$parent[UserControl].((viewModels:ConfigViewModel)DataContext).Mpr121CapacitiveCount" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </DataTemplate>
