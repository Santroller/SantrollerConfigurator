                                              IsEnabled="False"
                                              Content="{x:Static netCore:Resources.DetectedLabel}" />
                                </StackPanel>
                                <Label Foreground="Red" Margin="45 0 0 0"
                                       Content="{Binding Mpr121ErrorText}"
                                       VerticalAlignment="Bottom"
                                       HorizontalAlignment="Center"
                                       HorizontalContentAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       IsVisible="{Binding Mpr121ErrorText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal"
                                            IsVisible="{Binding !$parent[views:ConfigView].((viewModels:ConfigViewModel)DataContext).Branded}">
                                    <Button
                                        Command="{Binding RemoveMpr121Command}"
                                        Content="{x:Static netCore:Resources.RemoveLabel}" />
                                </StackPanel>
                            </Panel>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <StackPanel>
                        <StackPanel IsVisible="{Binding HasMpr121}">
                            <StackPanel IsVisible="{Binding BindableTwi}" Orientation="Horizontal">
                                <Label VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Width="350" Content="{x:Static netCore:Resources.SclLabel}" />
                                <ComboBox VerticalAlignment="Center"
                                          SelectedItem="{Binding Mpr121Scl}"
                                          ItemsSource="{Binding AvailableSclPinsInput}"
                                          DropDownOpened="ReloadPinTemplates"
                                          ItemTemplate="{StaticResource PinToStringTemplateTwi}"
                                          Width="200" />
                            </StackPanel>
                            <StackPanel IsVisible="{Binding BindableTwi}" Orientation="Horizontal">
                                <Label VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Width="350" Content="{x:Static netCore:Resources.SdaLabel}" />
                                <ComboBox VerticalAlignment="Center"
                                          SelectedItem="{Binding Mpr121Sda}"
                                          ItemsSource="{Binding AvailableSdaPinsInput}"
                                          DropDownOpened="ReloadPinTemplates"
                                          ItemTemplate="{StaticResource PinToStringTemplateTwi}"
                                          Width="200" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Label VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Width="350" Content="{x:Static netCore:Resources.Mpr121CapacativeCountLabel}" />

                                <NumericUpDown VerticalAlignment="Center" Width="200" FormatString="{}{0:#,0}"
                                               Value="{Binding Mpr121CapacitiveCount}"
                                               Minimum="0"
                                               Maximum="12" HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Expander>
                <Expander HorizontalAlignment="Stretch" Header="{Binding}"
                          IsExpanded="{Binding Max170XExpanded}">
                    <Expander.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="IsBluetoothTx" />
                            <Binding Path="!Branded" />
                            <Binding Path="HasMax1704X" />
                        </MultiBinding>
                    </Expander.IsVisible>
                    <Expander.HeaderTemplate>
                        <DataTemplate DataType="viewModels:ConfigViewModel">
                            <Panel>
                                <StackPanel Orientation="Horizontal">
                                    <Image Width="75"
                                           Source="avares://SantrollerConfigurator/Assets/Icons/Combined/Battery.png">
                                    </Image>
                                    <Label VerticalAlignment="Center"
                                           VerticalContentAlignment="Center"
                                           Content="{x:Static netCore:Resources.MAX1704xSettingsLabel}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="45 0 0 0" HorizontalAlignment="Center"
                                            IsVisible="{Binding HasMax1704X}">
                                    <CheckBox IsChecked="{Binding Max1704XConnected}" VerticalAlignment="Center"
                                              IsEnabled="False"
                                              Content="{x:Static netCore:Resources.DetectedLabel}" />
                                    <Label VerticalAlignment="Center"
                                           VerticalContentAlignment="Center"
                                           Content="{x:Static netCore:Resources.Max1704xStatusLabel}" />
                                    <Label VerticalAlignment="Center"
                                           VerticalContentAlignment="Center"
                                           Content="{Binding Max1704XStatus}" />
                                </StackPanel>
                                <Label Foreground="Red" Margin="45 0 0 0"
                                       Content="{Binding Max170XErrorText}"
                                       VerticalAlignment="Bottom"
                                       HorizontalAlignment="Center"
                                       HorizontalContentAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       IsVisible="{Binding Max170XErrorText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal"
                                            IsVisible="{Binding !$parent[views:ConfigView].((viewModels:ConfigViewModel)DataContext).Branded}">
                                    <Button
                                        Command="{Binding RemoveMax1704XCommand}"
                                        Content="{x:Static netCore:Resources.RemoveLabel}" />
                                </StackPanel>
                            </Panel>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <StackPanel>
                        <StackPanel IsVisible="{Binding HasMax1704X}">
                            <StackPanel IsVisible="{Binding BindableTwi}" Orientation="Horizontal">
                                <Label VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Width="350" Content="{x:Static netCore:Resources.SclLabel}" />
                                <ComboBox VerticalAlignment="Center"
                                          SelectedItem="{Binding Max1704XScl}"
                                          ItemsSource="{Binding AvailableSclPinsInput}"
                                          DropDownOpened="ReloadPinTemplates"
                                          ItemTemplate="{StaticResource PinToStringTemplateTwi}"
                                          Width="200" />
                            </StackPanel>
                            <StackPanel IsVisible="{Binding BindableTwi}" Orientation="Horizontal">
                                <Label VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Width="350" Content="{x:Static netCore:Resources.SdaLabel}" />
                                <ComboBox VerticalAlignment="Center"
                                          SelectedItem="{Binding Max1704XSda}"
                                          ItemsSource="{Binding AvailableSdaPinsInput}"
                                          DropDownOpened="ReloadPinTemplates"
                                          ItemTemplate="{StaticResource PinToStringTemplateTwi}"
                                          Width="200" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Expander>
                <Expander HorizontalAlignment="Stretch" Header="{Binding}"
                          IsExpanded="{Binding AccelExpanded}" IsVisible="{Binding HasAccel}">
                    <Expander.HeaderTemplate>
                        <DataTemplate DataType="viewModels:ConfigViewModel">
                            <Panel>
                                <StackPanel Orientation="Horizontal">
                                    <Image Width="75"
                                           Source="avares://SantrollerConfigurator/Assets/Icons/GuitarHeroGuitar/Tilt.png">
                                    </Image>
                                    <Label VerticalAlignment="Center"
                                           VerticalContentAlignment="Center"
                                           Content="{x:Static netCore:Resources.AccelerometerSettingsLabel}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="45 0 0 0" HorizontalAlignment="Center"
                                            IsVisible="{Binding HasAccel}">
                                    <CheckBox IsChecked="{Binding AccelConnected}" VerticalAlignment="Center"
                                              IsEnabled="False"
                                              Content="{x:Static netCore:Resources.DetectedLabel}" />
                                </StackPanel>
                                <Label Foreground="Red" Margin="45 0 0 0"
                                       Content="{Binding AccelErrorText}"
                                       VerticalAlignment="Bottom"
                                       HorizontalAlignment="Center"
                                       HorizontalContentAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       IsVisible="{Binding AccelErrorText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal"
                                            IsVisible="{Binding !Branded}">
                                    <Button
                                        Command="{Binding RemoveAccelCommand}"
                                        Content="{x:Static netCore:Resources.RemoveLabel}" />
                                </StackPanel>
                            </Panel>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <StackPanel>
                        <StackPanel IsVisible="{Binding !Branded}">
                            <StackPanel IsVisible="{Binding BindableTwi}" Orientation="Horizontal">
                                <Label VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Width="350" Content="{x:Static netCore:Resources.SclLabel}" />
                                <ComboBox VerticalAlignment="Center"
                                          SelectedItem="{Binding AccelScl}"
                                          ItemsSource="{Binding AvailableSclPinsInput}"
                                          DropDownOpened="ReloadPinTemplates"
                                          ItemTemplate="{StaticResource PinToStringTemplateTwi}"
                                          Width="200" />
                            </StackPanel>
                            <StackPanel IsVisible="{Binding BindableTwi}" Orientation="Horizontal">
                                <Label VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Width="350" Content="{x:Static netCore:Resources.SdaLabel}" />
                                <ComboBox VerticalAlignment="Center"
                                          SelectedItem="{Binding AccelSda}"
                                          ItemsSource="{Binding AvailableSdaPinsInput}"
                                          DropDownOpened="ReloadPinTemplates"
                                          ItemTemplate="{StaticResource PinToStringTemplateTwi}"
                                          Width="200" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <Label VerticalAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Width="350" Content="{x:Static netCore:Resources.LowPassFilterLabel}" />
                            <NumericUpDown Value="{Binding AccelFilter}" Minimum="0"
                                           Maximum="1" Width="200" Height="30" ShowButtonSpinner="False"
                                           AllowSpin="False" />
                        </StackPanel>
                    </StackPanel>
                </Expander>
                <ItemsControl ItemsSource="{Binding Outputs}" x:Name="OutputsContainer">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="output:Output">
                            <StackPanel>
                                <Expander IsVisible="{Binding !IsEmpty}" HorizontalAlignment="Stretch"
                                          Header="{Binding}" IsExpanded="{Binding Expanded}">
                                    <Expander.HeaderTemplate>
                                        <DataTemplate DataType="output:Output">
                                            <Panel Opacity="{Binding CombinedOpacity}">
                                                <StackPanel Orientation="Horizontal">
                                                    <ContentControl
                                                        ContentTemplate="{StaticResource ImageOutputTemplate}"
                                                        Content="{Binding }" />
                                                    <Label VerticalAlignment="Center"
                                                           VerticalContentAlignment="Center"
                                                           Content="{Binding LocalisedName}" />
                                                </StackPanel>
                                                <ContentControl Content="{Binding}" Margin="45 0 0 0"
                                                                HorizontalAlignment="Center"
                                                                ContentTemplate="{StaticResource OutputHeaderTemplates}" />

                                                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">

                                                    <ToggleSwitch HorizontalAlignment="Right"
                                                                  IsChecked="{Binding Enabled}"
                                                                  OnContent="{x:Static netCore:Resources.EnabledLabel}"
                                                                  OffContent="{x:Static netCore:Resources.DisabledLabel}">
                                                        <ToggleSwitch.IsVisible>
                                                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                                <Binding Path="!IsCombined" />
                                                                <Binding Path="!ChildOfCombined" />
                                                            </MultiBinding>
                                                        </ToggleSwitch.IsVisible>
                                                    </ToggleSwitch>
                                                    <StackPanel Orientation="Horizontal"
                                                                IsVisible="{Binding !$parent[views:ConfigView].((viewModels:ConfigViewModel)DataContext).Branded}">
                                                        <Button
                                                            Command="{Binding RemoveCommand}"
                                                            Content="{x:Static netCore:Resources.RemoveLabel}" />
                                                        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                                            <Button
                                                                Command="{Binding MoveUp}">
                                                                <Path HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"
                                                                      Stretch="None"
                                                                      Stroke="White"
                                                                      Data="M 0 7 L 7 0 L 14 7"
                                                                      StrokeThickness="1" />
                                                            </Button>
                                                            <Button
                                                                Command="{Binding MoveDown}">
                                                                <Path HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"
                                                                      Stretch="None"
                                                                      Stroke="White"
                                                                      Data="M 0 0 L 7 7 L 14 0"
                                                                      StrokeThickness="1" />
                                                            </Button>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </StackPanel>
                                                <Label Foreground="Red" Margin="45 0 0 0"
                                                       Content="{Binding ErrorText}"
                                                       VerticalAlignment="Bottom"
                                                       HorizontalAlignment="Center"
                                                       HorizontalContentAlignment="Center"
                                                       VerticalContentAlignment="Center"
                                                       IsVisible="{Binding ErrorText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                            </Panel>
                                        </DataTemplate>
                                    </Expander.HeaderTemplate>
                                    <StackPanel Opacity="{Binding CombinedOpacity}">
                                        <StackPanel Orientation="Horizontal" IsVisible="{Binding IsKeyboard}">
                                            <Label VerticalAlignment="Center"
                                                   VerticalContentAlignment="Center"
                                                   Width="350" Content="{x:Static netCore:Resources.OutputTypeLabel}" />
                                            <ComboBox VerticalAlignment="Center"
                                                      SelectedItem="{Binding KeyOrMouse}"
                                                      ItemsSource="{Binding KeyOrMouseInputs}"
                                                      ItemTemplate="{StaticResource EnumToStringTemplate}" />
                                            <Button Command="{Binding FindAndAssignCommand}"
                                                    IsEnabled="{Binding ConfigurableInput}"
                                                    Content="{Binding ButtonText}" />
                                        </StackPanel>
                                        <ContentControl ContentTemplate="{StaticResource OutputSelectionTemplate}"
                                                        Content="{Binding}" />

                                        <StackPanel Orientation="Horizontal">
                                            <StackPanel.IsVisible>
                                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                    <Binding
                                                        Path="!$parent[views:ConfigView].((viewModels:ConfigViewModel)DataContext).Branded" />
                                                    <Binding Path="!IsCombined" />
                                                    <Binding Path="!IsLed" />
                                                </MultiBinding>
                                            </StackPanel.IsVisible>
                                            <Label VerticalAlignment="Center"
                                                   VerticalContentAlignment="Center"
                                                   Width="350" Content="{x:Static netCore:Resources.InputTypeLabel}" />
                                            <ComboBox VerticalAlignment="Center"
                                                      SelectedItem="{Binding SelectedInputType}"
                                                      ItemsSource="{Binding InputTypes}"
                                                      ItemTemplate="{StaticResource ImageWithTextTemplateGeneric}" />
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal">
                                            <StackPanel.IsVisible>
                                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                    <Binding Path="ConfigurableInput" />
                                                    <Binding
                                                        Path="!$parent[views:ConfigView].((viewModels:ConfigViewModel)DataContext).Branded" />
                                                    <Binding Path="!IsCombined" />
                                                    <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                                        <Binding Path="IsWii" />
                                                        <Binding Path="IsDj" />
                                                        <Binding Path="IsPs2" />
                                                        <Binding Path="IsGh5OrClone" />
                                                        <Binding Path="IsWt" />
                                                        <Binding Path="IsUsb" />
                                                        <Binding Path="IsAccel" />
                                                    </MultiBinding>
                                                </MultiBinding>
                                            </StackPanel.IsVisible>
                                            <Label VerticalAlignment="Center"
                                                   VerticalContentAlignment="Center"
                                                   Width="350" Content="{x:Static netCore:Resources.InputLabel}" />
                                            <ComboBox VerticalAlignment="Center"
                                                      IsVisible="{Binding IsWii}"
                                                      SelectedItem="{Binding WiiInputType}"
                                                      ItemsSource="{Binding WiiInputTypes}"
                                                      ItemTemplate="{StaticResource ImageWithTextTemplate}" />
                                            <ComboBox VerticalAlignment="Center"
                                                      IsVisible="{Binding IsAccel}"
                                                      SelectedItem="{Binding AccelInputType}"
                                                      ItemsSource="{Binding AdxlInputTypes}"
                                                      ItemTemplate="{StaticResource ImageWithTextTemplate}" />
                                            <ComboBox VerticalAlignment="Center"
                                                      IsVisible="{Binding IsUsb}"
                                                      SelectedItem="{Binding UsbInputType}"
                                                      ItemsSource="{Binding UsbInputTypes}"
                                                      ItemTemplate="{StaticResource ImageWithTextTemplate}" />
                                            <ComboBox VerticalAlignment="Center"
                                                      IsVisible="{Binding IsDj}"
                                                      SelectedItem="{Binding DjInputType}"
                                                      ItemsSource="{Binding DjInputTypes}"
                                                      ItemTemplate="{StaticResource ImageWithTextTemplate}" />
                                            <ComboBox VerticalAlignment="Center"
                                                      IsVisible="{Binding IsPs2}"
                                                      SelectedItem="{Binding Ps2InputType}"
                                                      ItemsSource="{Binding Ps2InputTypes}"
                                                      ItemTemplate="{StaticResource ImageWithTextTemplate}" />
                                            <ComboBox VerticalAlignment="Center"
                                                      IsVisible="{Binding IsGh5OrClone}"
                                                      SelectedItem="{Binding Gh5NeckInputType}"
                                                      ItemsSource="{Binding Gh5NeckInputTypes}"
                                                      ItemTemplate="{StaticResource ImageWithTextTemplate}" />
                                            <ComboBox VerticalAlignment="Center"
                                                      IsVisible="{Binding IsWt}"
                                                      SelectedItem="{Binding GhWtInputType}"
                                                      ItemsSource="{Binding GhWtInputTypes}"
                                                      ItemTemplate="{StaticResource ImageWithTextTemplate}" />
                                            <ComboBox VerticalAlignment="Center"
                                                      IsVisible="{Binding IsMidi}"
                                                      SelectedItem="{Binding MidiType}"
                                                      ItemsSource="{Binding MidiTypes}"
                                                      ItemTemplate="{StaticResource ImageWithTextTemplate}" />
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" IsVisible="{Binding IsMidiNote}">
                                            <Label VerticalAlignment="Center"
                                                   VerticalContentAlignment="Center"
                                                   Width="350" Content="{x:Static netCore:Resources.MidiNote}" />
                                            <ComboBox VerticalAlignment="Center"
                                                      SelectedItem="{Binding MidiNote}"
                                                      ItemsSource="{Binding MidiNotes}"
                                                      ItemTemplate="{StaticResource MidiNoteTemplate}" />
                                            <Button Command="{Binding FindAndAssignMidiNoteCommand}"
                                                    IsEnabled="{Binding ConfigurableInput}"
                                                    Content="{Binding ButtonTextMidiNote}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" IsVisible="{Binding IsUsbHostKeyboard}">
                                            <Label VerticalAlignment="Center"
                                                   VerticalContentAlignment="Center"
                                                   Width="350" Content="{x:Static netCore:Resources.KeyTypeLabel}" />
                                            <ComboBox VerticalAlignment="Center"
                                                      SelectedItem="{Binding UsbHostKey}"
                                                      ItemsSource="{Binding KeyboardButtons}"
                                                      ItemTemplate="{StaticResource EnumToStringTemplate}" />
                                            <Button Command="{Binding FindAndAssignUsbHostKeyCommand}"
                                                    IsEnabled="{Binding ConfigurableInput}"
                                                    Content="{Binding ButtonTextUsbHostKey}" />
                                        </StackPanel>


                                        <StackPanel Orientation="Horizontal" IsVisible="{Binding IsUsbHostMouseAxis}">
                                            <Label VerticalAlignment="Center"
                                                   VerticalContentAlignment="Center"
                                                   Width="350"
                                                   Content="{x:Static netCore:Resources.MouseAxisTypeLabel}" />
                                            <ComboBox VerticalAlignment="Center"
                                                      SelectedItem="{Binding UsbHostKeyMouseAxisType}"
                                                      ItemsSource="{Binding MouseAxisTypes}"
                                                      ItemTemplate="{StaticResource EnumToStringTemplate}" />
                                            <Button Command="{Binding FindAndAssignUsbHostMouseAxisCommand}"
                                                    IsEnabled="{Binding ConfigurableInput}"
                                                    Content="{Binding ButtonTextUsbHostKey}" />
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" IsVisible="{Binding IsUsbHostMouseButton}">
                                            <Label VerticalAlignment="Center"
                                                   VerticalContentAlignment="Center"
                                                   Width="350"
                                                   Content="{x:Static netCore:Resources.MouseButtonTypeLabel}" />
                                            <ComboBox VerticalAlignment="Center"
                                                      SelectedItem="{Binding UsbHostKeyMouseButtonType}"
                                                      ItemsSource="{Binding MouseButtonTypes}"
                                                      ItemTemplate="{StaticResource EnumToStringTemplate}" />
                                            <Button Command="{Binding FindAndAssignUsbHostMouseButtonCommand}"
                                                    IsEnabled="{Binding ConfigurableInput}"
                                                    Content="{Binding ButtonTextUsbHostKey}" />
                                        </StackPanel>
                                        <ContentControl ContentTemplate="{StaticResource OutputTemplate}"
                                                        Content="{Binding}" />

                                        <ItemsControl IsVisible="{Binding IsCombined}"
                                                      HorizontalAlignment="Stretch"
                                                      IsEnabled="{Binding IsCombined}"
                                                      ItemsSource="{Binding DigitalOutputs}"
                                                      ItemTemplate="{StaticResource CombinedOutputTemplate}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                        <ItemsControl IsVisible="{Binding IsCombined}"
                                                      HorizontalAlignment="Stretch"
                                                      IsEnabled="{Binding IsCombined}"
                                                      ItemsSource="{Binding AnalogOutputs}"
                                                      ItemTemplate="{StaticResource CombinedOutputTemplate}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </StackPanel>
                                </Expander>
                                <ContentControl IsVisible="{Binding IsEmpty}"
                                                ContentTemplate="{StaticResource EmptySelector}"
                                                Content="{Binding}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Expander HorizontalAlignment="Stretch" Header="{Binding}"
                          IsExpanded="{Binding TestExpanded}" IsVisible="{Binding Branded}">
                    <Expander.HeaderTemplate>
                        <DataTemplate DataType="viewModels:ConfigViewModel">
                            <Panel>
                                <StackPanel Orientation="Horizontal">
                                    <Image Width="75"
                                           Source="avares://SantrollerConfigurator/Assets/Icons/Generic.png">
                                    </Image>
                                    <Label VerticalAlignment="Center"
                                           VerticalContentAlignment="Center"
                                           Content="{x:Static netCore:Resources.ButtonTestLabel}" />
                                </StackPanel>
                            </Panel>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <StackPanel>
                        <ItemsControl HorizontalAlignment="Stretch"
                                      ItemsSource="{Binding DigitalOutputs}"
                                      ItemTemplate="{StaticResource DigitalOutputTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </Panel>
</UserControl>