                    </StackPanel>
                </StackPanel>
            </DataTemplate>
            <DataTemplate DataType="{x:Type output:OutputButton}">
                <StackPanel Orientation="Horizontal"
                            IsVisible="{Binding $parent[UserControl].((viewModels:ConfigViewModel)DataContext).LocalDebounceMode}">
                    <Label VerticalAlignment="Center"
                           VerticalContentAlignment="Center"
                           Width="350" Content="{x:Static netCore:Resources.DebounceLabel}" />
                    <NumericUpDown FormatString="{}{0:#,0}" Value="{Binding DebounceDisplay}"
                                   IsVisible="{Binding !$parent[UserControl].((viewModels:ConfigViewModel)DataContext).Deque}"
                                   VerticalAlignment="Center"
                                   Width="200" />
                    <NumericUpDown Increment="0.1" Value="{Binding DebounceDisplay}"
                                   IsVisible="{Binding $parent[UserControl].((viewModels:ConfigViewModel)DataContext).Deque}"
                                   VerticalAlignment="Center"
                                   Width="200" />
                </StackPanel>
            </DataTemplate>

            <DataTemplate DataType="{x:Type inputs:ConstantInput}">
                <StackPanel
                    IsVisible="{Binding !$parent[views:ConfigView].((viewModels:ConfigViewModel)DataContext).Branded}">
                    <StackPanel Orientation="Horizontal" IsVisible="{Binding Normal}">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.ValueLabel}" />
                        <NumericUpDown FormatString="{}{0:#,0}" Value="{Binding Value}" Minimum="{Binding Min}"
                                       Maximum="{Binding Max}"
                                       VerticalAlignment="Center"
                                       Width="200" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" IsVisible="{Binding !IsAnalog}">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.ValueLabel}" />
                        <ToggleSwitch HorizontalAlignment="Right" IsChecked="{Binding ValueBool}" OnContent="On"
                                      OffContent="Off" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" IsVisible="{Binding RbPickup}">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="Selected Notch" />
                        <NumericUpDown FormatString="{}{0:#,0}" Value="{Binding PickupSelectorType}" Minimum="1"
                                       Maximum="5"
                                       VerticalAlignment="Center"
                                       Width="200" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" IsVisible="{Binding TapBar}">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.ValueLabel}" />
                        <CheckBox IsChecked="{Binding Green}" VerticalAlignment="Center"
                                  Content="{x:Static netCore:Resources.TapBarCurrentFretsGreen}" />
                        <CheckBox IsChecked="{Binding Red}" VerticalAlignment="Center"
                                  Content="{x:Static netCore:Resources.TapBarCurrentFretsRed}" />
                        <CheckBox IsChecked="{Binding Yellow}" VerticalAlignment="Center"
                                  Content="{x:Static netCore:Resources.TapBarCurrentFretsYellow}" />
                        <CheckBox IsChecked="{Binding Blue}" VerticalAlignment="Center"
                                  Content="{x:Static netCore:Resources.TapBarCurrentFretsBlue}" />
                        <CheckBox IsChecked="{Binding Orange}" VerticalAlignment="Center"
                                  Content="{x:Static netCore:Resources.TapBarCurrentFretsOrange}" />
                    </StackPanel>
                </StackPanel>
            </DataTemplate>
            <DataTemplate DataType="{x:Type conversions:AnalogToDigital}">
                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Horizontal"
                                IsVisible="{Binding !$parent[views:ConfigView].((viewModels:ConfigViewModel)DataContext).Branded}">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.TypeLabel}" />
                        <ComboBox HorizontalAlignment="Stretch" ItemTemplate="{StaticResource EnumToStringTemplate}"
                                  SelectedItem="{Binding AnalogToDigitalType}"
                                  ItemsSource="{Binding AnalogToDigitalTypes}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.ThresholdLabel}" />

                        <StackPanel Orientation="Vertical">
                            <Grid>
                                <StackPanel Orientation="Horizontal" IsVisible="{Binding IsUint}">
                                    <ProgressBar Opacity="0.5" Value="{Binding RawAnalogValue}"
                                                 IsIndeterminate="False" Minimum="0" Maximum="65536"
                                                 Height="30"
                                                 Width="{Binding FullProgressWidth, Mode=OneTime}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" IsVisible="{Binding !IsUint}"
                                            Width="{Binding FullProgressWidth, Mode=OneTime}">
                                    <ProgressBar Opacity="0.5" CornerRadius="0 3 3 0"
                                                 Value="{Binding ValueLower}"
                                                 IsIndeterminate="False" Minimum="0" Maximum="32768"
                                                 Height="30"
                                                 Width="{Binding HalfProgressWidth, Mode=OneTime}">
                                        <ProgressBar.RenderTransform>
                                            <ScaleTransform ScaleX="-1" />
                                        </ProgressBar.RenderTransform>
                                    </ProgressBar>
                                    <ProgressBar Opacity="0.5" CornerRadius="0 3 3 0"
                                                 Value="{Binding ValueUpper}"
                                                 IsIndeterminate="False" Minimum="0" Maximum="32768"
                                                 Height="30"
                                                 Width="{Binding HalfProgressWidth, Mode=OneTime}" />
                                </StackPanel>
                                <Label VerticalAlignment="Center" HorizontalContentAlignment="Center"
                                       Content="{Binding RawAnalogValue}"
                                       Width="{Binding FullProgressWidth, Mode=OneTime}" />
                                <Slider Foreground="White" VerticalAlignment="Center"
                                        Width="{Binding FullProgressWidth, Mode=OneTime}" Height="50"
                                        Minimum="{Binding Min, Mode=OneTime}"
                                        Maximum="{Binding Max, Mode=OneTime}" Value="{Binding DisplayThreshold}" />
                            </Grid>

                            <NumericUpDown FormatString="{}{0:#,0}"
                                           Minimum="{Binding Min, Mode=OneTime}"
                                           Maximum="{Binding Max, Mode=OneTime}"
                                           Value="{Binding DisplayThreshold}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Left"
                                           Width="200" />
                        </StackPanel>
                    </StackPanel>
                    <ContentControl Content="{Binding Child}"
                                    ContentTemplate="{StaticResource OutputTemplates}" />
                </StackPanel>
            </DataTemplate>
            <DataTemplate DataType="{x:Type conversions:DigitalToAnalog}">
                <StackPanel>
                    <ContentControl Content="{Binding Child}"
                                    ContentTemplate="{StaticResource OutputTemplates}" />
                    <StackPanel IsVisible="{Binding Normal}" Orientation="Horizontal">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.ValueLabel}" />
                        <NumericUpDown FormatString="{}{0:#,0}" Value="{Binding On}" Minimum="{Binding Minimum}"
                                       Maximum="{Binding Maximum}"
                                       VerticalAlignment="Center"
                                       Width="200" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" IsVisible="{Binding RbPickup}">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.ValueLabel}" />
                        <NumericUpDown FormatString="{}{0:#,0}" Value="{Binding PickupSelectorType}" Minimum="1"
                                       Maximum="5"
                                       VerticalAlignment="Center"
                                       Width="200" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" IsVisible="{Binding TapBar}">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.ValueLabel}" />
                        <CheckBox IsChecked="{Binding Green}" VerticalAlignment="Center"
                                  Content="{x:Static netCore:Resources.TapBarCurrentFretsGreen}" />
                        <CheckBox IsChecked="{Binding Red}" VerticalAlignment="Center"
                                  Content="{x:Static netCore:Resources.TapBarCurrentFretsRed}" />
                        <CheckBox IsChecked="{Binding Yellow}" VerticalAlignment="Center"
                                  Content="{x:Static netCore:Resources.TapBarCurrentFretsYellow}" />
                        <CheckBox IsChecked="{Binding Blue}" VerticalAlignment="Center"
                                  Content="{x:Static netCore:Resources.TapBarCurrentFretsBlue}" />
                        <CheckBox IsChecked="{Binding Orange}" VerticalAlignment="Center"
                                  Content="{x:Static netCore:Resources.TapBarCurrentFretsOrange}" />
                    </StackPanel>
                </StackPanel>
            </DataTemplate>
            <DataTemplate DataType="{x:Type inputs:MacroInput}">
                <StackPanel
                    IsVisible="{Binding !$parent[views:ConfigView].((viewModels:ConfigViewModel)DataContext).Branded}">
                    <StackPanel Orientation="Horizontal">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.InputTypeLabel}" />
                        <ComboBox VerticalAlignment="Center"
                                  SelectedItem="{Binding SelectedInputType1}"
                                  ItemsSource="{Binding InputTypes}"
                                  ItemTemplate="{StaticResource ImageWithTextTemplateGeneric}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <StackPanel.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                <Binding Path="IsWii" />
                                <Binding Path="IsDj" />
                                <Binding Path="IsPs2" />
                                <Binding Path="IsUsb" />
                                <Binding Path="IsMidi" />
                            </MultiBinding>
                        </StackPanel.IsVisible>
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.Input1InputLabel}" />
                        <ComboBox VerticalAlignment="Center"
                                  IsVisible="{Binding IsWii}"
                                  SelectedItem="{Binding WiiInputType1}"
                                  ItemsSource="{Binding WiiInputTypes}"
                                  ItemTemplate="{StaticResource ImageWithTextTemplate}" />
                        <ComboBox VerticalAlignment="Center"
                                  IsVisible="{Binding IsDj}"
                                  SelectedItem="{Binding DjInputType1}"
                                  ItemsSource="{Binding DjInputTypes}"
                                  ItemTemplate="{StaticResource ImageWithTextTemplate}" />
                        <ComboBox VerticalAlignment="Center"
                                  IsVisible="{Binding IsPs2}"
                                  SelectedItem="{Binding Ps2InputType1}"
                                  ItemsSource="{Binding Ps2InputTypes}"
                                  ItemTemplate="{StaticResource ImageWithTextTemplate}" />
                        <ComboBox VerticalAlignment="Center"
                                  IsVisible="{Binding IsUsb}"
                                  SelectedItem="{Binding UsbInputType1}"
                                  ItemsSource="{Binding UsbInputTypes}"
                                  ItemTemplate="{StaticResource ImageWithTextTemplate}" />
                        <ComboBox VerticalAlignment="Center"
                                  IsVisible="{Binding IsMidi}"
                                  SelectedItem="{Binding MidiType1}"
                                  ItemsSource="{Binding MidiTypes}"
                                  ItemTemplate="{StaticResource ImageWithTextTemplate}" />

                        <ComboBox VerticalAlignment="Center"
                                  IsVisible="{Binding IsMidiNote1}"
                                  SelectedItem="{Binding MidiNote1}"
                                  ItemsSource="{Binding MidiNotes}"
                                  ItemTemplate="{StaticResource MidiNoteTemplate}" />
                        <!-- <Button Command="{Binding FindAndAssignMidiNoteCommand}" -->
                        <!--         IsEnabled="{Binding ConfigurableInput}" -->
                        <!--         Content="{Binding ButtonTextMidiNote}" /> -->
                    </StackPanel>
                    <ContentControl Content="{Binding Child1}"
                                    ContentTemplate="{StaticResource OutputTemplates}">

                        <ContentControl.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                <Binding Path="!IsWii" />
                                <Binding Path="!IsDj" />
                                <Binding Path="!IsPs2" />
                                <Binding Path="!IsUsb" />

                            </MultiBinding>
                        </ContentControl.IsVisible>
                    </ContentControl>

                    <StackPanel Orientation="Horizontal">
                        <StackPanel.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                <Binding Path="IsWii" />
                                <Binding Path="IsDj" />
                                <Binding Path="IsPs2" />
                                <Binding Path="IsUsb" />
                                <Binding Path="IsMidi" />
                            </MultiBinding>
                        </StackPanel.IsVisible>
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.Input2InputLabel}" />
                        <ComboBox VerticalAlignment="Center"
                                  IsVisible="{Binding IsWii}"
                                  SelectedItem="{Binding WiiInputType2}"
                                  ItemsSource="{Binding WiiInputTypes}"
                                  ItemTemplate="{StaticResource ImageWithTextTemplate}" />
                        <ComboBox VerticalAlignment="Center"
                                  IsVisible="{Binding IsDj}"
                                  SelectedItem="{Binding DjInputType2}"
                                  ItemsSource="{Binding DjInputTypes}"
                                  ItemTemplate="{StaticResource ImageWithTextTemplate}" />
                        <ComboBox VerticalAlignment="Center"
                                  IsVisible="{Binding IsPs2}"
                                  SelectedItem="{Binding Ps2InputType2}"
                                  ItemsSource="{Binding Ps2InputTypes}"
                                  ItemTemplate="{StaticResource ImageWithTextTemplate}" />
                        <ComboBox VerticalAlignment="Center"
                                  IsVisible="{Binding IsUsb}"
                                  SelectedItem="{Binding UsbInputType2}"
                                  ItemsSource="{Binding UsbInputTypes}"
                                  ItemTemplate="{StaticResource ImageWithTextTemplate}" />
                        <ComboBox VerticalAlignment="Center"
                                  IsVisible="{Binding IsMidi}"
                                  SelectedItem="{Binding MidiType2}"
                                  ItemsSource="{Binding MidiTypes}"
                                  ItemTemplate="{StaticResource ImageWithTextTemplate}" />

                        <ComboBox VerticalAlignment="Center"
                                  IsVisible="{Binding IsMidiNote2}"
                                  SelectedItem="{Binding MidiNote2}"
                                  ItemsSource="{Binding MidiNotes}"
                                  ItemTemplate="{StaticResource MidiNoteTemplate}" />
                    </StackPanel>
                    <ContentControl Content="{Binding Child2}"
                                    ContentTemplate="{StaticResource OutputTemplates}" />
                </StackPanel>
            </DataTemplate>
            <DataTemplate DataType="{x:Type combined:DjCombinedOutput}">
                <StackPanel>
                    <StackPanel>
                        <StackPanel IsVisible="{Binding BindableTwi}" Orientation="Horizontal">
                            <Label VerticalAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Width="350" Content="{x:Static netCore:Resources.SclLabel}" />
                            <ComboBox VerticalAlignment="Center"
                                      SelectedItem="{Binding Scl}"
                                      ItemsSource="{Binding AvailableSclPins}"
                                      DropDownOpened="ReloadPinTemplates"
                                      ItemTemplate="{StaticResource PinToStringTemplate}"
                                      Width="200" />
                        </StackPanel>
                        <StackPanel IsVisible="{Binding BindableTwi}" Orientation="Horizontal">
                            <Label VerticalAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Width="350" Content="{x:Static netCore:Resources.SdaLabel}" />
                            <ComboBox VerticalAlignment="Center"
                                      SelectedItem="{Binding Sda}"
                                      ItemsSource="{Binding AvailableSdaPins}"
                                      DropDownOpened="ReloadPinTemplates"
                                      ItemTemplate="{StaticResource PinToStringTemplate}"
                                      Width="200" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.TurntablePollRateLabel}" />
                        <NumericUpDown FormatString="{}{0:#,0}" Value="{Binding PollRate}" Minimum="1"
                                       Maximum="10" Width="200" Height="30" />
                    </StackPanel>
                </StackPanel>
            </DataTemplate>
            <DataTemplate DataType="{x:Type combined:WiiCombinedOutput}">
                <StackPanel>
                    <StackPanel IsVisible="{Binding BindableTwi}" Orientation="Horizontal">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.SclLabel}" />
                        <ComboBox VerticalAlignment="Center"
                                  SelectedItem="{Binding Scl}"
                                  ItemsSource="{Binding AvailableSclPins}"
                                  DropDownOpened="ReloadPinTemplates"
                                  ItemTemplate="{StaticResource PinToStringTemplate}"
                                  Width="200" />
                    </StackPanel>
                    <StackPanel IsVisible="{Binding BindableTwi}" Orientation="Horizontal">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.SdaLabel}" />
                        <ComboBox VerticalAlignment="Center"
                                  SelectedItem="{Binding Sda}"
                                  ItemsSource="{Binding AvailableSdaPins}"
                                  DropDownOpened="ReloadPinTemplates"
                                  ItemTemplate="{StaticResource PinToStringTemplate}"
                                  Width="200" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.WiiInputFilterLabel}" />
                        <ComboBox VerticalAlignment="Center"
                                  SelectedItem="{Binding SelectedType}"
                                  ItemsSource="{Binding WiiControllerTypes}"
                                  ItemTemplate="{StaticResource EnumToStringTemplate}"
                                  Width="200" />
                    </StackPanel>
                    <Label IsVisible="{Binding IsTurntable}" VerticalAlignment="Center"
                           VerticalContentAlignment="Center"
                           Foreground="Red"
                           Content="{x:Static netCore:Resources.TurntableNote1}" />
                    <Label IsVisible="{Binding IsTurntable}" VerticalAlignment="Center"
                           VerticalContentAlignment="Center"
                           Foreground="Red"
                           Content="{x:Static netCore:Resources.TurntableNote2}" />
                </StackPanel>
            </DataTemplate>
            <DataTemplate DataType="{x:Type combined:CombinedTwiOutput}">
                <StackPanel>
                    <StackPanel IsVisible="{Binding BindableTwi}" Orientation="Horizontal">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.SclLabel}" />
                        <ComboBox VerticalAlignment="Center"
                                  SelectedItem="{Binding Scl}"
                                  ItemsSource="{Binding AvailableSclPins}"
                                  DropDownOpened="ReloadPinTemplates"
                                  ItemTemplate="{StaticResource PinToStringTemplate}"
                                  Width="200" />
                    </StackPanel>
                    <StackPanel IsVisible="{Binding BindableTwi}" Orientation="Horizontal">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.SdaLabel}" />
                        <ComboBox VerticalAlignment="Center"
                                  SelectedItem="{Binding Sda}"
                                  ItemsSource="{Binding AvailableSdaPins}"
                                  DropDownOpened="ReloadPinTemplates"
                                  ItemTemplate="{StaticResource PinToStringTemplate}"
                                  Width="200" />
                    </StackPanel>
                </StackPanel>
            </DataTemplate>
            <DataTemplate DataType="{x:Type combined:CombinedUartOutput}">
                <StackPanel>
                    <StackPanel IsVisible="{Binding BindableUart}" Orientation="Horizontal">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.TXPin}" />
                        <ComboBox VerticalAlignment="Center"
                                  SelectedItem="{Binding Tx}"
                                  ItemsSource="{Binding AvailableTxPins}"
                                  DropDownOpened="ReloadPinTemplates"
                                  ItemTemplate="{StaticResource PinToStringTemplate}"
                                  Width="200" />
                    </StackPanel>
                    <StackPanel IsVisible="{Binding BindableUart}" Orientation="Horizontal">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.RXPin}" />
                        <ComboBox VerticalAlignment="Center"
                                  SelectedItem="{Binding Rx}"
                                  ItemsSource="{Binding AvailableRxPins}"
                                  DropDownOpened="ReloadPinTemplates"
                                  ItemTemplate="{StaticResource PinToStringTemplate}"
                                  Width="200" />
                    </StackPanel>
                </StackPanel>
            </DataTemplate>
            <DataTemplate DataType="{x:Type combined:GhwtCombinedOutput}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.SliderBarSensitivityLabel}" />
                        <NumericUpDown FormatString="{}{0:#,0}" Value="{Binding Sensitivity}" Maximum="1000"
                                       VerticalAlignment="Center"
                                       Width="200" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="Raw Values" />
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{Binding RawTaps}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.SliderAnalogInputPin}" />
                        <ComboBox VerticalAlignment="Center"
                                  SelectedItem="{Binding Pin}"
                                  ItemsSource="{Binding AvailablePinsDigital}"
                                  DropDownOpened="ReloadPinTemplates"
                                  ItemTemplate="{StaticResource PinToStringTemplate}"
                                  Width="200" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.SliderS0Pin}" />
                        <ComboBox VerticalAlignment="Center"
                                  SelectedItem="{Binding PinS0}"
                                  ItemsSource="{Binding AvailablePinsDigital}"
                                  DropDownOpened="ReloadPinTemplates"
                                  ItemTemplate="{StaticResource PinToStringTemplate}"
                                  Width="200" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.SliderS1Pin}" />
                        <ComboBox VerticalAlignment="Center"
                                  SelectedItem="{Binding PinS1}"
                                  ItemsSource="{Binding AvailablePinsDigital}"
                                  DropDownOpened="ReloadPinTemplates"
                                  ItemTemplate="{StaticResource PinToStringTemplate}"
                                  Width="200" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.SliderS2Pin}" />
                        <ComboBox VerticalAlignment="Center"
                                  SelectedItem="{Binding PinS2}"
                                  ItemsSource="{Binding AvailablePinsDigital}"
                                  DropDownOpened="ReloadPinTemplates"
                                  ItemTemplate="{StaticResource PinToStringTemplate}"
                                  Width="200" />
                    </StackPanel>
                </StackPanel>
            </DataTemplate>


            <DataTemplate DataType="{x:Type combined:MidiCombinedOutput}">
                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Horizontal"
                                IsVisible="{Binding $parent[views:ConfigView].((viewModels:ConfigViewModel)DataContext).IsProKeys}">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.ProKeysInitialNoteLabel}" />
                        <ComboBox VerticalAlignment="Center"
                                  SelectedItem="{Binding MidiNote}"
                                  ItemsSource="{Binding MidiNotesFirst}"
                                  ItemTemplate="{StaticResource MidiNoteTemplate}" />
                        <Button Command="{Binding FindAndAssignMidiNoteCommand}"
                                Content="{Binding ButtonTextMidiNote}" />
                    </StackPanel>
                    <StackPanel
                        IsVisible="{Binding !$parent[views:ConfigView].((viewModels:ConfigViewModel)DataContext).Branded}">
                        <StackPanel Orientation="Vertical"
                                    IsVisible="{Binding $parent[views:ConfigView].((viewModels:ConfigViewModel)DataContext).IsPico}">
                            <StackPanel Orientation="Horizontal">
                                <Label VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Width="350" Content="{x:Static netCore:Resources.MidiSerialEnabled}" />

                                <ToggleSwitch HorizontalAlignment="Right"
                                              IsChecked="{Binding MidiSerialEnabled}"
                                              OnContent="{x:Static netCore:Resources.EnabledLabel}"
                                              OffContent="{x:Static netCore:Resources.DisabledLabel}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        IsVisible="{Binding MidiSerialEnabled}">
                                <Label VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Width="350" Content="{x:Static netCore:Resources.MidiSerialEnabled}" />
                                <ComboBox VerticalAlignment="Center"
                                          SelectedItem="{Binding MidiSerialPin}"
                                          ItemsSource="{Binding ValidSerialPins}"
                                          DropDownOpened="ReloadPinTemplates"
                                          ItemTemplate="{StaticResource PinToStringTemplate}"
                                          Width="200" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </DataTemplate>
            <DataTemplate DataType="{x:Type combined:Ps2CombinedOutput}">
                <StackPanel>
                    <StackPanel IsVisible="{Binding BindableSpi}" Orientation="Horizontal">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.MosiLabel}" />
                        <ComboBox VerticalAlignment="Center"
                                  SelectedItem="{Binding Mosi}"
                                  ItemsSource="{Binding AvailableMosiPins}"
                                  DropDownOpened="ReloadPinTemplates"
                                  ItemTemplate="{StaticResource PinToStringTemplate}"
                                  Width="200" />
                    </StackPanel>

                    <StackPanel IsVisible="{Binding BindableSpi}" Orientation="Horizontal">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.MisoLabel}" />
                        <ComboBox VerticalAlignment="Center"
                                  SelectedItem="{Binding Miso}"
                                  ItemsSource="{Binding AvailableMisoPins}"
                                  ItemTemplate="{StaticResource PinToStringTemplate}"
                                  Width="200" />
                    </StackPanel>

                    <StackPanel IsVisible="{Binding BindableSpi}" Orientation="Horizontal">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.SckLabel}" />
                        <ComboBox VerticalAlignment="Center"
                                  SelectedItem="{Binding Sck}"
                                  ItemsSource="{Binding AvailableSckPins}"
                                  DropDownOpened="ReloadPinTemplates"
                                  ItemTemplate="{StaticResource PinToStringTemplate}"
                                  Width="200" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                IsVisible="{Binding !$parent[views:ConfigView].((viewModels:ConfigViewModel)DataContext).Branded}">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.AckLabel}" />
                        <ComboBox VerticalAlignment="Center"
                                  SelectedItem="{Binding Ack}"
                                  ItemsSource="{Binding AvailablePinsInterrupt}"
                                  ItemTemplate="{StaticResource PinToStringTemplate}"
                                  DropDownOpened="ReloadPinTemplates"
                                  Width="200" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                IsVisible="{Binding BindableAtt}">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.AttentionLabel}" />
                        <ComboBox VerticalAlignment="Center"
                                  SelectedItem="{Binding Att}"
                                  ItemsSource="{Binding AvailablePins}"
                                  ItemTemplate="{StaticResource PinToStringTemplate}"
                                  DropDownOpened="ReloadPinTemplates"
                                  Width="200" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.PS2InputFilterLabel}" />
                        <ComboBox VerticalAlignment="Center"
                                  SelectedItem="{Binding SelectedType}"
                                  ItemsSource="{Binding Ps2ControllerTypes}"
                                  ItemTemplate="{StaticResource EnumToStringTemplate}"
                                  Width="200" />
                    </StackPanel>
                </StackPanel>
            </DataTemplate>
            <DataTemplate />
        </netCore:OutputTemplateSelector>
        <DataTemplate DataType="output:Output" x:Key="OutputTemplate">
            <StackPanel>
                <Panel>
                    <StackPanel>
                        <Label HorizontalAlignment="Center" IsVisible="{Binding ChildOfCombined}"
                               Content="{Binding Title}" />
                        <StackPanel Orientation="Horizontal">
                            <ContentControl IsVisible="{Binding ChildOfCombined}"
                                            ContentTemplate="{StaticResource ImageOutputTemplate}"
                                            HorizontalAlignment="Left" Width="75" Margin="0 0 10 10"
                                            Content="{Binding }" />
                        </StackPanel>
                    </StackPanel>
                    <ToggleSwitch HorizontalAlignment="Right" IsVisible="{Binding ChildOfCombined}"
                                  IsChecked="{Binding Enabled}" OnContent="{x:Static netCore:Resources.EnabledLabel}"
                                  OffContent="{x:Static netCore:Resources.DisabledLabel}" />
                </Panel>
                <ContentControl Content="{Binding Input}"
                                ContentTemplate="{StaticResource OutputTemplates}" />

                <ContentControl Content="{Binding}"
                                ContentTemplate="{StaticResource OutputTemplates}" />
                <WrapPanel Orientation="Horizontal">
                    <WrapPanel.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="AreLedsEnabled" />
                            <Binding Path="SupportsLeds" />
                            <Binding Path="!IsCombined" />
                            <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                <Binding
                                    Path="!$parent[views:ConfigView].((viewModels:ConfigViewModel)DataContext).Branded" />
                                <Binding Path="AreLedsSet" />
                                <Binding Path="AreLedsSetPeripheral" />
                            </MultiBinding>
                        </MultiBinding>
                    </WrapPanel.IsVisible>
                    <Label VerticalAlignment="Center"
                           VerticalContentAlignment="Center" Width="350" IsVisible="{Binding IsApa102 }"
                           Content="{x:Static netCore:Resources.SelectedLEDsApa102Label}" />
                    <Label VerticalAlignment="Center"
                           VerticalContentAlignment="Center" Width="350" IsVisible="{Binding IsWs2812 }"
                           Content="{x:Static netCore:Resources.SelectedLEDsWS2812Label}" />
                    <Label VerticalAlignment="Center"
                           VerticalContentAlignment="Center" Width="350" IsVisible="{Binding IsStp }"
                           Content="{x:Static netCore:Resources.SelectedLEDsStpLabel}" />
                    <ItemsControl ItemsSource="{Binding AvailableIndices}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="output:LedIndex">
                                <ToggleButton IsChecked="{Binding Selected }"
                                              Content="{Binding Index}" Width="50" HorizontalContentAlignment="Center" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </WrapPanel>
                <WrapPanel Orientation="Horizontal">
                    <WrapPanel.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="AreLedsEnabledPeripheral" />
                            <Binding Path="SupportsLeds" />
                            <Binding Path="!IsCombined" />
                        </MultiBinding>
                    </WrapPanel.IsVisible>
                    <Label VerticalAlignment="Center"
                           VerticalContentAlignment="Center" Width="350" IsVisible="{Binding IsApa102Peripheral }"
                           Content="{x:Static netCore:Resources.SelectedLEDsPeripheralApa102Label}" />
                    <Label VerticalAlignment="Center"
                           VerticalContentAlignment="Center" Width="350" IsVisible="{Binding IsWs2812Peripheral }"
                           Content="{x:Static netCore:Resources.SelectedLEDsPeripheralWS2812Label}" />
                    <Label VerticalAlignment="Center"
                           VerticalContentAlignment="Center" Width="350" IsVisible="{Binding IsStpPeripheral }"
                           Content="{x:Static netCore:Resources.SelectedLEDsPeripheralStpLabel}" />
                    <ItemsControl ItemsSource="{Binding AvailableIndicesPeripheral}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="output:LedIndex">
                                <ToggleButton IsChecked="{Binding Selected }"
                                              Content="{Binding Index}" Width="50" HorizontalContentAlignment="Center" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </WrapPanel>
                <WrapPanel Orientation="Horizontal">
                    <WrapPanel.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="Model.HasMpr121" />
                            <Binding Path="SupportsLeds" />
                            <Binding Path="!IsCombined" />
                        </MultiBinding>
                    </WrapPanel.IsVisible>
                    <Label VerticalAlignment="Center"
                           VerticalContentAlignment="Center" Width="350"
                           Content="{x:Static netCore:Resources.SelectedLEDsMpr121Label}" />
                    <ItemsControl ItemsSource="{Binding AvailableIndicesMpr121}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="output:LedIndex">
                                <ToggleButton IsChecked="{Binding Selected }"
                                              Content="{Binding Index}" Width="50" HorizontalContentAlignment="Center" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </WrapPanel>
                <StackPanel Orientation="Horizontal">
                    <StackPanel.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                <Binding Path="!IsApa102" />
                                <Binding Path="!IsApa102Peripheral" />
                            </MultiBinding>
                            <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                <Binding
                                    Path="!$parent[views:ConfigView].((viewModels:ConfigViewModel)DataContext).Branded" />
                                <Binding Path="AreLedsSet" />
                                <Binding Path="AreLedsSetPeripheral" />
                            </MultiBinding>
                            <Binding Path="!IsCombined" />
                            <Binding Path="SupportsLeds" />
                            <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                <Binding Path="AreLedsEnabled" />
                                <Binding Path="AreLedsEnabledPeripheral" />
                            </MultiBinding>
                        </MultiBinding>
                    </StackPanel.IsVisible>
                    <Label VerticalAlignment="Center"
                           VerticalContentAlignment="Center" Width="350"
                           Content="{x:Static netCore:Resources.TestLEDLabel}" />
                    <Button HorizontalAlignment="Center"
                            Width="200"
                            Command="{Binding TestLEDs}"
                            HorizontalContentAlignment="Center" Content="{x:Static netCore:Resources.TestLEDLabel}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <StackPanel.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="SupportsLeds" />
                            <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                <Binding Path="LedsUseColours" />
                                <Binding Path="LedsUseColoursPeripheral" />
                            </MultiBinding>
                            <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                <Binding
                                    Path="!$parent[views:ConfigView].((viewModels:ConfigViewModel)DataContext).Branded" />
                                <Binding Path="AreLedsSet" />
                                <Binding Path="AreLedsSetPeripheral" />
                            </MultiBinding>
                            <Binding Path="!IsCombined" />
                            <Binding Path="LedsHaveColours" />
                        </MultiBinding>
                    </StackPanel.IsVisible>
                    <Label VerticalAlignment="Center"
                           VerticalContentAlignment="Center" Width="350"
                           Content="{Binding LedOnLabel}" />

                    <StackPanel Orientation="Horizontal">
                        <ColorPicker IsAlphaEnabled="False" IsAlphaVisible="False" ColorSpectrumShape="Ring"
                                     Color="{Binding LedOn}" />

                        <Button Command="{Binding CopyOff}"
                                HorizontalAlignment="Stretch" Width="350" HorizontalContentAlignment="Center"
                                Content="{x:Static netCore:Resources.CopyOtherLedLabel}" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <StackPanel.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                <Binding Path="LedsUseColours" />
                                <Binding Path="LedsUseColoursPeripheral" />
                            </MultiBinding>
                            <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                <Binding
                                    Path="!$parent[views:ConfigView].((viewModels:ConfigViewModel)DataContext).Branded" />
                                <Binding Path="AreLedsSet" />
                                <Binding Path="AreLedsSetPeripheral" />
                            </MultiBinding>
                            <Binding Path="!IsCombined" />
                            <Binding Path="SupportsLeds" />
                            <Binding Path="LedsHaveColours" />
                            <Binding Path="SupportsLedOff" />
                        </MultiBinding>
                    </StackPanel.IsVisible>
                    <Label VerticalAlignment="Center"
                           VerticalContentAlignment="Center" Width="350"
                           Content="{Binding LedOffLabel}" />
                    <ColorPicker IsAlphaEnabled="False" IsAlphaVisible="False" ColorSpectrumShape="Ring"
                                 Color="{Binding LedOff}" />
                    <Button Command="{Binding CopyOn}"
                            HorizontalAlignment="Stretch" Width="350" HorizontalContentAlignment="Center"
                            Content="{x:Static netCore:Resources.CopyOtherLedLabel}" />
                </StackPanel>
                <StackPanel>
                    <StackPanel.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="!IsCombined" />
                            <Binding Path="!UsesPwm" />
                            <Binding Path="LedsHaveColours" />
                            <Binding Path="SupportsLeds" />
                            <Binding
                                Path="!$parent[views:ConfigView].((viewModels:ConfigViewModel)DataContext).Branded">
                            </Binding>
                        </MultiBinding>
                    </StackPanel.IsVisible>
                    <StackPanel Orientation="Horizontal">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.EnableDigitalOutputTitle}" />
                        <ToggleSwitch IsChecked="{Binding OutputEnabled}"
                                      OnContent="{x:Static netCore:Resources.EnabledLabel}"
                                      OffContent="{x:Static netCore:Resources.DisabledLabel}" />
                    </StackPanel>
                </StackPanel>
                <StackPanel>
                    <StackPanel.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="UsesPwm" />
                            <Binding Path="LedsHaveColours" />
                            <Binding Path="SupportsLeds" />
                            <Binding
                                Path="!$parent[views:ConfigView].((viewModels:ConfigViewModel)DataContext).Branded">
                            </Binding>
                        </MultiBinding>
                    </StackPanel.IsVisible>
                    <StackPanel Orientation="Horizontal">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.EnableAnalogOutputTitle}" />
                        <ToggleSwitch IsChecked="{Binding OutputEnabled}"
                                      OnContent="{x:Static netCore:Resources.EnabledLabel}"
                                      OffContent="{x:Static netCore:Resources.DisabledLabel}" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <StackPanel.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="OutputEnabled" />
                            <Binding
                                Path="!$parent[views:ConfigView].((viewModels:ConfigViewModel)DataContext).Branded">
                            </Binding>
                        </MultiBinding>
                    </StackPanel.IsVisible>
                    <Label VerticalAlignment="Center"
                           VerticalContentAlignment="Center"
                           Width="350" Content="{x:Static netCore:Resources.InvertOutputLabel}" />
                    <ToggleSwitch IsChecked="{Binding OutputInverted}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <StackPanel.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="Model.HasPeripheral" />
                            <Binding Path="OutputEnabled" />
                            <Binding Path="SupportsLeds" />
                        </MultiBinding>
                    </StackPanel.IsVisible>
                    <Label VerticalAlignment="Center"
                           VerticalContentAlignment="Center"
                           Width="350" Content="{x:Static netCore:Resources.PeripheralOutputLabel}" />
                    <ToggleSwitch IsChecked="{Binding PeripheralOutput}" />
                </StackPanel>
                <StackPanel IsVisible="{Binding UsesPwm}">
                    <StackPanel Orientation="Horizontal" IsVisible="{Binding OutputEnabled}">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               IsVisible="{Binding UsesPwm}"
                               Width="350" Content="{x:Static netCore:Resources.TestLabel}" />
                        <Slider Value="{Binding Test}"
                                Minimum="1"
                                Maximum="255"
                                IsSnapToTickEnabled="True"
                                TickFrequency="1" Width="240" />
                    </StackPanel>
                </StackPanel>
                <StackPanel IsVisible="{Binding !UsesPwm}">
                    <StackPanel Orientation="Horizontal" IsVisible="{Binding OutputEnabled}">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               IsVisible="{Binding !UsesPwm}"
                               Width="350" Content="{x:Static netCore:Resources.TestLabelDigital}" />
                        <ToggleSwitch IsChecked="{Binding TestDigital}" />
                    </StackPanel>
                </StackPanel>
                <StackPanel>
                    <StackPanel.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="UsesPwm" />
                            <Binding Path="OutputEnabled" />
                            <Binding Path="SupportsLeds" />
                            <Binding
                                Path="!$parent[views:ConfigView].((viewModels:ConfigViewModel)DataContext).Branded">
                            </Binding>
                        </MultiBinding>
                    </StackPanel.IsVisible>
                    <StackPanel Orientation="Horizontal">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.AnalogOutputPinLabel}" />
                        <ComboBox VerticalAlignment="Center"
                                  SelectedItem="{Binding OutputPin}"
                                  DropDownOpened="ReloadPinTemplates"
                                  ItemTemplate="{StaticResource PinToStringTemplate}"
                                  ItemsSource="{Binding AvailablePwmPins}" />
                    </StackPanel>
                </StackPanel>
                <StackPanel>
                    <StackPanel.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="!UsesPwm" />
                            <Binding Path="OutputEnabled" />
                            <Binding Path="SupportsLeds" />
                            <Binding
                                Path="!$parent[views:ConfigView].((viewModels:ConfigViewModel)DataContext).Branded">
                            </Binding>
                        </MultiBinding>
                    </StackPanel.IsVisible>
                    <StackPanel Orientation="Horizontal" IsVisible="{Binding OutputEnabled}">
                        <Label VerticalAlignment="Center"
                               VerticalContentAlignment="Center"
                               Width="350" Content="{x:Static netCore:Resources.DigitalOutputPinLabel}" />
                        <ComboBox VerticalAlignment="Center"
                                  SelectedItem="{Binding OutputPin}"
                                  DropDownOpened="ReloadPinTemplates"
                                  ItemTemplate="{StaticResource PinToStringTemplate}"
                                  ItemsSource="{Binding AvailablePins}" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </DataTemplate>
        <DataTemplate DataType="output:Output" x:Key="CombinedOutputTemplate">
            <StackPanel Margin="0 5 10 5" Background="{Binding CombinedBackground}" Opacity="{Binding CombinedOpacity}">
                <ContentControl Padding="10" Content="{Binding}"
                                ContentTemplate="{StaticResource OutputTemplate}"
                                Background="{Binding CombinedBackground}"
                                Width="775" />
                <Label Foreground="Red" Margin="45 0 0 0"
                       Content="{Binding ErrorText}"
                       VerticalAlignment="Bottom"
                       HorizontalAlignment="Center"
                       HorizontalContentAlignment="Center"
                       VerticalContentAlignment="Center"
                       IsVisible="{Binding ErrorText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            </StackPanel>
        </DataTemplate>
        <DataTemplate DataType="output:Output" x:Key="DigitalOutputTemplate">
            <StackPanel>
                <Panel>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ContentControl ContentTemplate="{StaticResource ImageOutputTemplate}"
                                            HorizontalAlignment="Left" Width="75" Margin="0 0 10 10"
                                            Content="{Binding }" />
                        </StackPanel>
                    </StackPanel>
                </Panel>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>
    <Panel>
        <ScrollViewer VerticalContentAlignment="Center">
            <StackPanel>
                <Expander HorizontalAlignment="Stretch" Header="{Binding}"
                          IsExpanded="{Binding ControllerConfigExpanded}">
                    <Expander.HeaderTemplate>
                        <DataTemplate DataType="viewModels:ConfigViewModel">
                            <Panel>
                                <StackPanel Orientation="Horizontal">
                                    <Image Width="75"
                                           Source="avares://SantrollerConfigurator/Assets/Icons/Generic.png">
                                    </Image>
                                    <Label VerticalAlignment="Center"
                                           VerticalContentAlignment="Center"
                                           Content="{x:Static netCore:Resources.ControllerSettingsLabel}" />
                                </StackPanel>
                            </Panel>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <StackPanel>
                        <StackPanel IsVisible="{Binding !Branded}">
                            <StackPanel Orientation="Horizontal">
                                <Label VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Width="350" Content="{x:Static netCore:Resources.ControllerTypeLabel}" />
                                <ComboBox HorizontalAlignment="Stretch" Width="200"
                                          SelectedItem="{Binding DeviceControllerType}"
                                          ItemTemplate="{StaticResource EnumToStringTemplate}"
                                          ItemsSource="{Binding DeviceControllerRhythmTypes}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" IsVisible="{Binding IsKeyboard}">
                                <Label VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Width="350" Content="{x:Static netCore:Resources.MouseMovementTypeLabel}" />
                                <ComboBox HorizontalAlignment="Stretch" Width="200"
                                          SelectedItem="{Binding MouseMovementType}"
                                          ItemTemplate="{StaticResource EnumToStringTemplate}"
                                          ItemsSource="{Binding MouseMovementTypes}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <StackPanel.IsVisible>
                                    <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                        <Binding Path="IsKeyboard" />
                                        <Binding Path="IsFortniteFestivalPro" />
                                    </MultiBinding>
                                </StackPanel.IsVisible>
                                <Label VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Width="350" Content="{x:Static netCore:Resources.RolloverModeLabel}" />
                                <ComboBox HorizontalAlignment="Stretch" Width="200"
                                          SelectedItem="{Binding RolloverMode}"
                                          ItemTemplate="{StaticResource EnumToStringTemplate}"
                                          ItemsSource="{Binding RolloverModes}" />
                            </StackPanel>

                        </StackPanel>
                        <StackPanel Orientation="Horizontal" IsVisible="{Binding IsStandardController}">
                            <Label VerticalAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Width="350" Content="{x:Static netCore:Resources.SwapSwitchFaceButtonLabel}" />
                            <ToggleSwitch HorizontalAlignment="Center" Width="200"
                                          HorizontalContentAlignment="Center"
                                          IsChecked="{Binding SwapSwitchFaceButtons}"
                                          OnContent="{x:Static netCore:Resources.EnabledLabel}"
                                          OffContent="{x:Static netCore:Resources.DisabledLabel}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" IsVisible="{Binding IsStandardController}">
                            <Label VerticalAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Width="350" Content="{x:Static netCore:Resources.WindowsControllerModeLabel}" />
                            <ComboBox HorizontalAlignment="Stretch" Width="200"
                                      SelectedIndex="{Binding XInputOnWindows}">
                                <ComboBoxItem Content="{x:Static netCore:Resources.HIDGameControllerLabel}" />
                                <ComboBoxItem Content="{x:Static netCore:Resources.XInputLabel}" />
                            </ComboBox>

                        </StackPanel>
                        <StackPanel Orientation="Horizontal" IsVisible="{Binding IsStandardController}">
                            <Label VerticalAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Width="350" Content="{x:Static netCore:Resources.InvertHidYAxis}" />
                            <ToggleSwitch HorizontalAlignment="Center" Width="200"
                                          HorizontalContentAlignment="Center"
                                          IsChecked="{Binding InvertHidYAxis}"
                                          OnContent="{x:Static netCore:Resources.InvertLabel}"
                                          OffContent="{x:Static netCore:Resources.SectionTypeNormal}" />

                        </StackPanel>


                        <StackPanel Orientation="Horizontal" IsVisible="{Binding IsTurntable}">
                            <Label VerticalAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Width="350" Content="{x:Static netCore:Resources.TurntableNavButtons}" />
                            <ToggleSwitch HorizontalAlignment="Center" Width="200"
                                          HorizontalContentAlignment="Center"
                                          IsChecked="{Binding DjNavButtons}"
                                          OnContent="{x:Static netCore:Resources.EnabledLabel}"
                                          OffContent="{x:Static netCore:Resources.DisabledLabel}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" IsVisible="{Binding IsTurntable}">
                            <Label VerticalAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Width="350" Content="{x:Static netCore:Resources.TurntableNavButtons}" />
                            <ToggleSwitch HorizontalAlignment="Center" Width="200"
                                          HorizontalContentAlignment="Center"
                                          IsChecked="{Binding DjNavButtons}"
                                          OnContent="{x:Static netCore:Resources.EnabledLabel}"
                                          OffContent="{x:Static netCore:Resources.DisabledLabel}" />
                        </StackPanel>


                        <StackPanel Orientation="Horizontal" IsVisible="{Binding IsTurntable}">
                            <Label VerticalAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Width="350" Content="{x:Static netCore:Resources.TurntableRange}" />
                            <ToggleSwitch HorizontalAlignment="Center" Width="200"
                                          HorizontalContentAlignment="Center"
                                          IsChecked="{Binding DjFullRange}"
                                          OnContent="{x:Static netCore:Resources.EnabledLabel}"
                                          OffContent="{x:Static netCore:Resources.DisabledLabel}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" IsVisible="{Binding IsRpcs3CompatibleController}">
                            <Label VerticalAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Width="350" Content="{x:Static netCore:Resources.RPCS3CompatLabel}" />
                            <ToggleSwitch HorizontalAlignment="Center" Width="200"
                                          HorizontalContentAlignment="Center"
                                          IsChecked="{Binding Ps3OnRpcs3}"
                                          OnContent="{x:Static netCore:Resources.EnabledLabel}"
                                          OffContent="{x:Static netCore:Resources.DisabledLabel}" />
                        </StackPanel>
                        
                        <StackPanel IsVisible="{Binding !Branded}">
                        <StackPanel Orientation="Horizontal" IsVisible="{Binding IsRbDrumKit}">
                            <Label VerticalAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Width="350" Content="{x:Static netCore:Resources.Rb3CymbalFix}" />
                            <ToggleSwitch HorizontalAlignment="Center" Width="200"
                                          HorizontalContentAlignment="Center"
                                          IsChecked="{Binding CymbalGlitchFix}"
                                          OnContent="{x:Static netCore:Resources.EnabledLabel}"
                                          OffContent="{x:Static netCore:Resources.DisabledLabel}" />
                        </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" IsVisible="{Binding IsGuitar}">
                            <Label VerticalAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Width="350" IsVisible="{Binding Ps4Instruments}" Content="{x:Static netCore:Resources.SelectDpadLeftXb1PS4}" />
                            <Label VerticalAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Width="350" IsVisible="{Binding !Ps4Instruments}" Content="{x:Static netCore:Resources.SelectDpadLeftXb1}" />
                            <ToggleSwitch HorizontalAlignment="Center" Width="200"
                                          HorizontalContentAlignment="Center"
                                          IsChecked="{Binding SelectDpadLeftXb1}"
                                          OnContent="{x:Static netCore:Resources.EnabledLabel}"
                                          OffContent="{x:Static netCore:Resources.DisabledLabel}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <StackPanel.IsVisible>
                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                    <Binding Path="UsbHostEnabled" />
                                    <Binding Path="!Branded" />
                                </MultiBinding>
                            </StackPanel.IsVisible>
                            <Label VerticalAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Width="350" Content="{x:Static netCore:Resources.AdafruitUsbHost}" />
                            <ToggleSwitch HorizontalAlignment="Center" Width="200"
                                          HorizontalContentAlignment="Center"
                                          IsChecked="{Binding AdafruitHost}"
                                          OnContent="{x:Static netCore:Resources.EnabledLabel}"
                                          OffContent="{x:Static netCore:Resources.DisabledLabel}" />
                        </StackPanel>

                        <StackPanel Orientation="Vertical" IsVisible="{Binding IsBluetooth}">
                            <StackPanel Orientation="Horizontal">
                                <Label VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Width="350" Content="{x:Static netCore:Resources.SleepLabel}" />
                                <ToggleSwitch HorizontalAlignment="Center" Width="200"
                                              HorizontalContentAlignment="Center"
                                              IsChecked="{Binding SleepEnabled}"
                                              OnContent="{x:Static netCore:Resources.EnabledLabel}"
                                              OffContent="{x:Static netCore:Resources.DisabledLabel}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" IsVisible="{Binding SleepEnabled}">
                                <Label VerticalAlignment="Center" Width="350"
                                       Content="{x:Static netCore:Resources.SleepWakeupLabel}" />
                                <ComboBox Width="200"
                                          DropDownOpened="ReloadPinTemplates"
                                          SelectedItem="{Binding SleepWakeUpPin}"
                                          ItemsSource="{Binding AvailablePinsDigital}"
                                          ItemTemplate="{StaticResource PinToStringTemplate}" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" IsVisible="{Binding SleepEnabled}">
                                <Label VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Width="350" Content="{x:Static netCore:Resources.SleepTimeoutLabel}" />
                                <NumericUpDown FormatString="{}{0:#,0}"
                                               Value="{Binding DeviceSleep}"
                                               Minimum="5"
                                               Increment="1"
                                               Width="200"
                                               Maximum="65535" HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Expander>
                <Expander HorizontalAlignment="Stretch" Header="{Binding}" IsExpanded="{Binding PollExpanded}">
                    <Expander.HeaderTemplate>
                        <DataTemplate DataType="viewModels:ConfigViewModel">
                            <Panel>
                                <StackPanel Orientation="Horizontal">
                                    <Image Width="75"
                                           Source="avares://SantrollerConfigurator/Assets/Icons/Combined/PollRate.png">
                                    </Image>
                                    <Label VerticalAlignment="Center"
                                           VerticalContentAlignment="Center"
                                           Content="{x:Static netCore:Resources.PollSettingsLabel}" />
                                </StackPanel>
                            </Panel>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label VerticalAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Width="350" Content="{Binding PollRateLabel }" />
                            <NumericUpDown FormatString="{}{0:#,0}"
                                           Value="{Binding PollRate}"
                                           Width="200"
                                           Minimum="{Binding MinPollRate}"
                                           Maximum="10" HorizontalAlignment="Stretch" />
                        </StackPanel>
                        <StackPanel IsVisible="{Binding !LocalDebounceMode}">
                            <StackPanel Orientation="Horizontal" IsVisible="{Binding Deque}">
                                <Label VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Width="350" Content="{x:Static netCore:Resources.DebounceLabel}" />
                                <NumericUpDown Value="{Binding DebounceDisplay}"
                                               Minimum="0.5"
                                               Increment="0.1"
                                               Width="200"
                                               Maximum="25" HorizontalAlignment="Stretch" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" IsVisible="{Binding !Deque}">
                                <Label VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Width="350" Content="{x:Static netCore:Resources.DebounceExtraLabel}" />
                                <NumericUpDown FormatString="{}{0:#,0}"
                                               Value="{Binding DebounceDisplay}"
                                               Minimum="0"
                                               Increment="1"
                                               Width="200"
                                               Maximum="250" HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel IsVisible="{Binding IsGuitar}" Orientation="Horizontal">
                            <Label VerticalAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Width="350" Content="{x:Static netCore:Resources.StrumDebounceLabel}" />
                            <NumericUpDown Width="200" FormatString="{}{0:#,0}"
                                           Value="{Binding StrumDebounceDisplay}"
                                           Minimum="0"
                                           Maximum="25" HorizontalAlignment="Stretch" />
                        </StackPanel>
                        <StackPanel IsVisible="{Binding IsGuitar}" Orientation="Horizontal">
                            <Label VerticalAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Width="350"
                                   Content="{x:Static netCore:Resources.CombinedStrumDebounceLabel}" />
                            <ToggleSwitch HorizontalAlignment="Right"
                                          HorizontalContentAlignment="Right"
                                          IsChecked="{Binding CombinedStrumDebounce}"
                                          OnContent="{x:Static netCore:Resources.StrumCombinedLabel}"
                                          OffContent="{x:Static netCore:Resources.StrumIndividualLabel}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label VerticalAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Width="350" Content="{x:Static netCore:Resources.DebouceModeLabel}" />
                            <ComboBox HorizontalAlignment="Stretch" Width="200"
                                      SelectedIndex="{Binding LocalDebounceMode}">
                                <ComboBoxItem Content="{x:Static netCore:Resources.DebouceModeGlobalLabel}" />
                                <ComboBoxItem Content="{x:Static netCore:Resources.DebouceModePerInputLabel}" />
                            </ComboBox>
                        </StackPanel>
                        <StackPanel IsVisible="{Binding SupportsDeque}">
                            <StackPanel IsVisible="{Binding IsGuitar}" Orientation="Horizontal">
                                <Label VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Width="350" Content="{x:Static netCore:Resources.QueueBasedInputsLabel}" />
                                <ToggleSwitch HorizontalAlignment="Center"
                                              Width="200"
                                              HorizontalContentAlignment="Center" IsChecked="{Binding Deque}"
                                              OnContent="{x:Static netCore:Resources.EnabledLabel}"
                                              OffContent="{x:Static netCore:Resources.DisabledLabel}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Expander>
                <Expander HorizontalAlignment="Stretch" Header="{Binding}" IsVisible="{Binding !Branded}"
                          IsExpanded="{Binding PresetsExpanded}">
                    <Expander.HeaderTemplate>
                        <DataTemplate DataType="viewModels:ConfigViewModel">
                            <Panel>
                                <StackPanel Orientation="Horizontal">
                                    <Image Width="75"
                                           Source="avares://SantrollerConfigurator/Assets/Icons/Combined/Presets.png">
                                    </Image>
                                    <Label VerticalAlignment="Center"
                                           VerticalContentAlignment="Center"
                                           Content="{x:Static netCore:Resources.PresetLabel}" />
                                </StackPanel>
                            </Panel>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label VerticalAlignment="Center" Width="350"
                                   Content="{x:Static netCore:Resources.ImportConfigLabel}" />
                            <Button Command="{Binding LoadConfigCommand}"
                                    HorizontalAlignment="Stretch" Width="350" HorizontalContentAlignment="Center"
                                    Content="{x:Static netCore:Resources.ImportConfigLabel}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label VerticalAlignment="Center" Width="350"
                                   Content="{x:Static netCore:Resources.ExportConfigLabel}" />
                            <Button Command="{Binding SaveConfigCommand}"
                                    HorizontalAlignment="Stretch" Width="350" HorizontalContentAlignment="Center"
                                    Content="{x:Static netCore:Resources.ExportConfigLabel}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label VerticalAlignment="Center" Width="350"
                                   Content="{x:Static netCore:Resources.SavePresetLabel}" />
                            <TextBox Width="350" Text="{Binding PresetName}"></TextBox>
                            <Button Command="{Binding SavePresetCommand}"
                                    IsEnabled="{Binding PresetName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                    HorizontalAlignment="Stretch" Width="350" HorizontalContentAlignment="Center"
                                    Content="{Binding SavePresetLabel}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label VerticalAlignment="Center" Width="350"
                                   Content="{x:Static netCore:Resources.PresetLabel}" />
                            <ComboBox Width="350"
                                      IsEnabled="{Binding Presets.Count}"
                                      SelectedItem="{Binding CurrentPreset}"
                                      ItemsSource="{Binding Presets}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Item1, Mode=OneWay}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label VerticalAlignment="Center" Width="350"
                                   Content="{x:Static netCore:Resources.LoadPresetSimple}" />
                            <Button Command="{Binding LoadPresetCommand}"
                                    IsEnabled="{Binding Presets.Count}"
                                    HorizontalAlignment="Stretch" Width="350" HorizontalContentAlignment="Center"
                                    Content="{Binding LoadPresetLabel}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label VerticalAlignment="Center" Width="350"
                                   Content="{x:Static netCore:Resources.DeletePresetLabel}" />
                            <Button Command="{Binding DeletePresetCommand}"
                                    IsEnabled="{Binding Presets.Count}"
                                    HorizontalAlignment="Stretch" Width="350" HorizontalContentAlignment="Center"
                                    Content="{Binding DeletePresetLabel}" />
                        </StackPanel>
                    </StackPanel>
                </Expander>
                <Expander HorizontalAlignment="Stretch" Header="{Binding}"
                          IsExpanded="{Binding LedConfigExpanded}">

                    <Expander.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.Or}">
                            <Binding Path="!Branded" />
                            <Binding
                                Path="IsApa102" />
                            <Binding Path="IsApa102Peripheral" />
                        </MultiBinding>
                    </Expander.IsVisible>
                    <Expander.HeaderTemplate>
                        <DataTemplate DataType="viewModels:ConfigViewModel">
                            <Panel>
                                <StackPanel Orientation="Horizontal">
                                    <Image Width="75"
                                           Source="avares://SantrollerConfigurator/Assets/Icons/Combined/Led.png">
                                    </Image>
                                    <Label VerticalAlignment="Center"
                                           VerticalContentAlignment="Center"
                                           Content="{x:Static netCore:Resources.LEDSettingsLabel}" />
                                </StackPanel>
                                <Label Foreground="Red" Margin="45 0 0 0"
                                       Content="{Binding LedErrorText}"
                                       VerticalAlignment="Bottom"
                                       HorizontalAlignment="Center"
                                       HorizontalContentAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       IsVisible="{Binding LedErrorText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                            </Panel>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <StackPanel>
                        <StackPanel IsVisible="{Binding !Branded}">
                            <StackPanel Orientation="Horizontal" IsVisible="{Binding !Branded}">
                                <Label VerticalAlignment="Center" Width="350"
                                       Content="{x:Static netCore:Resources.LEDTypeLabel}" />
                                <ComboBox Width="200"
                                          SelectedItem="{Binding LedType}"
                                          ItemTemplate="{StaticResource EnumToStringTemplate}"
                                          ItemsSource="{Binding LedTypes}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" IsVisible="{Binding IsIndexedLed}">
                                <Label VerticalAlignment="Center" Width="350"
                                       Content="{x:Static netCore:Resources.LEDTypeCountLabel}" />
                                <NumericUpDown Width="200" FormatString="{}{0:#,0}"
                                               Value="{Binding LedCount}"
                                               Minimum="1"
                                               Maximum="180" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <StackPanel.IsVisible>
                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                        <Binding Path="BindableSpi" />
                                        <Binding Path="IsIndexedLed" />
                                        <Binding Path="!IsWs2812" />
                                    </MultiBinding>
                                </StackPanel.IsVisible>
                                <Label VerticalAlignment="Center" Width="350" IsVisible="{Binding IsApa102}"
                                       Content="{x:Static netCore:Resources.APA102SCKLabel}" />
                                <Label VerticalAlignment="Center" Width="350" IsVisible="{Binding IsStp16}"
                                       Content="{x:Static netCore:Resources.STP16CPC26SCKLabel}" />
                                <ComboBox Width="200"
                                          SelectedItem="{Binding LedSck}"
                                          ItemsSource="{Binding AvailableSckPins}"
                                          DropDownOpened="ReloadPinTemplates"
                                          ItemTemplate="{StaticResource PinToStringTemplateSpi}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <StackPanel.IsVisible>
                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                        <Binding Path="BindableSpi" />
                                        <Binding Path="IsIndexedLed" />
                                        <Binding Path="!IsWs2812" />
                                    </MultiBinding>
                                </StackPanel.IsVisible>
                                <Label IsVisible="{Binding IsApa102}" VerticalAlignment="Center" Width="350"
                                       Content="{x:Static netCore:Resources.APA102MOSILabel}" />
                                <Label VerticalAlignment="Center" Width="350" IsVisible="{Binding IsStp16}"
                                       Content="{x:Static netCore:Resources.STP16CPC26MOSILabel}" />
                                <ComboBox Width="200"
                                          SelectedItem="{Binding LedMosi}"
                                          ItemsSource="{Binding AvailableMosiPinsInput}"
                                          DropDownOpened="ReloadPinTemplates"
                                          ItemTemplate="{StaticResource PinToStringTemplateSpi}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <StackPanel.IsVisible>
                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                        <Binding Path="BindableSpi" />
                                        <Binding Path="IsIndexedLed" />
                                        <Binding Path="IsWs2812" />
                                    </MultiBinding>
                                </StackPanel.IsVisible>
                                <Label IsVisible="{Binding IsWs2812}" VerticalAlignment="Center" Width="350"
                                       Content="{x:Static netCore:Resources.WS2812MOSILabel}" />
                                <ComboBox Width="200"
                                          SelectedItem="{Binding Ws2812Data}"
                                          ItemsSource="{Binding AvailablePinsDigital}"
                                          DropDownOpened="ReloadPinTemplates"
                                          ItemTemplate="{StaticResource PinToStringTemplate}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" IsVisible="{Binding IsStp16}">
                                <Label VerticalAlignment="Center" Width="350"
                                       Content="{x:Static netCore:Resources.STP16CPC26OELabel}" />
                                <ComboBox Width="200"
                                          DropDownOpened="ReloadPinTemplates"
                                          SelectedItem="{Binding Stp16Oe}"
                                          ItemsSource="{Binding AvailablePinsDigital}"
                                          ItemTemplate="{StaticResource PinToStringTemplate}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" IsVisible="{Binding IsStp16}">
                                <Label VerticalAlignment="Center" Width="350"
                                       Content="{x:Static netCore:Resources.STP16CPC26LELabel}" />
                                <ComboBox Width="200"
                                          DropDownOpened="ReloadPinTemplates"
                                          SelectedItem="{Binding Stp16Le}"
                                          ItemsSource="{Binding AvailablePinsDigital}"
                                          ItemTemplate="{StaticResource PinToStringTemplate}" />
                            </StackPanel>
                            <StackPanel IsVisible="{Binding HasPeripheral}" Orientation="Horizontal">
                                <Label VerticalAlignment="Center" Width="350"
                                       Content="{x:Static netCore:Resources.LEDTypePeripheralLabel}" />

                                <ComboBox VerticalAlignment="Center" Width="200"
                                          SelectedItem="{Binding LedTypePeripheral}"
                                          ItemTemplate="{StaticResource EnumToStringTemplate}"
                                          ItemsSource="{Binding LedTypes}" />
                            </StackPanel>
                            <StackPanel IsVisible="{Binding IsIndexedLedPeripheral}" Orientation="Horizontal">
                                <Label VerticalAlignment="Center" Width="350"
                                       Content="{x:Static netCore:Resources.LEDTypePeripheralCountLabel}" />
                                <NumericUpDown VerticalAlignment="Center" Width="200" FormatString="{}{0:#,0}"
                                               Value="{Binding LedCountPeripheral}"
                                               Minimum="1"
                                               Maximum="180" HorizontalAlignment="Stretch" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <StackPanel.IsVisible>
                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                        <Binding Path="BindableSpi" />
                                        <Binding Path="IsIndexedLedPeripheral" />
                                        <Binding Path="!IsWs2812Peripheral" />
                                    </MultiBinding>
                                </StackPanel.IsVisible>
                                <Label IsVisible="{Binding IsApa102Peripheral}" VerticalAlignment="Center" Width="350"
                                       Content="{x:Static netCore:Resources.APA102SCKPeripheralLabel}" />
                                <Label IsVisible="{Binding IsStp16Peripheral}" VerticalAlignment="Center" Width="350"
                                       Content="{x:Static netCore:Resources.STP16CPC26SCKPeripheralLabel}" />
                                <ComboBox VerticalAlignment="Center" Width="200"
                                          SelectedItem="{Binding LedSckPeripheral}"
                                          ItemsSource="{Binding AvailableSckPins}"
                                          DropDownOpened="ReloadPinTemplates"
                                          ItemTemplate="{StaticResource PinToStringTemplatePeripheralSpi}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <StackPanel.IsVisible>
                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                        <Binding Path="BindableSpi" />
                                        <Binding Path="IsIndexedLedPeripheral" />
                                        <Binding Path="!IsWs2812Peripheral" />
                                    </MultiBinding>
                                </StackPanel.IsVisible>
                                <Label IsVisible="{Binding IsApa102Peripheral}" VerticalAlignment="Center" Width="350"
                                       Content="{x:Static netCore:Resources.APA102MOSIPeripheralLabel}" />
                                <Label IsVisible="{Binding IsStp16Peripheral}" VerticalAlignment="Center" Width="350"
                                       Content="{x:Static netCore:Resources.STP16CPC26MOSIPeripheralLabel}" />
                                <ComboBox VerticalAlignment="Center" Width="200"
                                          SelectedItem="{Binding LedMosiPeripheral}"
                                          ItemsSource="{Binding AvailableMosiPinsInput}"
                                          DropDownOpened="ReloadPinTemplates"
                                          ItemTemplate="{StaticResource PinToStringTemplatePeripheralSpi}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <StackPanel.IsVisible>
                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                        <Binding Path="BindableSpi" />
                                        <Binding Path="IsIndexedLedPeripheral" />
                                        <Binding Path="IsWs2812Peripheral" />
                                    </MultiBinding>
                                </StackPanel.IsVisible>
                                <Label IsVisible="{Binding IsWs2812Peripheral}" VerticalAlignment="Center" Width="350"
                                       Content="{x:Static netCore:Resources.WS2812MOSIPeripheralLabel}" />
                                <ComboBox VerticalAlignment="Center" Width="200"
                                          SelectedItem="{Binding Ws2812DataPeripheral}"
                                          ItemsSource="{Binding AvailablePinsDigital}"
                                          DropDownOpened="ReloadPinTemplates"
                                          ItemTemplate="{StaticResource PinToStringTemplate}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" IsVisible="{Binding IsStp16Peripheral}">
                                <Label VerticalAlignment="Center" Width="350"
                                       Content="{x:Static netCore:Resources.STP16CPC26OEPeripheralLabel}" />
                                <ComboBox Width="200"
                                          DropDownOpened="ReloadPinTemplates"
                                          SelectedItem="{Binding Stp16OePeripheral}"
                                          ItemsSource="{Binding AvailablePinsDigital}"
                                          ItemTemplate="{StaticResource PinToStringTemplate}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" IsVisible="{Binding IsStp16Peripheral}">
                                <Label VerticalAlignment="Center" Width="350"
                                       Content="{x:Static netCore:Resources.STP16CPC26LEPeripheralLabel}" />
                                <ComboBox Width="200"
                                          SelectedItem="{Binding Stp16LePeripheral}"
                                          ItemsSource="{Binding AvailablePinsDigital}"
                                          DropDownOpened="ReloadPinTemplates"
                                          ItemTemplate="{StaticResource PinToStringTemplate}" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel>
                            <StackPanel.IsVisible>
                                <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                    <Binding
                                        Path="IsApa102" />
                                    <Binding Path="IsApa102Peripheral" />
                                </MultiBinding>
                            </StackPanel.IsVisible>
                            <StackPanel Orientation="Horizontal">
                                <Label VerticalAlignment="Center" Width="350"
                                       Content="{x:Static netCore:Resources.LedBrightnessOnLabel}" />
                                <NumericUpDown Height="30" Width="200" FormatString="{}{0:#,0}"
                                               Value="{Binding LedBrightnessOn}"
                                               Minimum="1"
                                               Maximum="31" />
                                <Slider Value="{Binding LedBrightnessOn}"
                                        Minimum="1"
                                        Maximum="31"
                                        IsSnapToTickEnabled="True"
                                        TickFrequency="1" Width="200" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Label VerticalAlignment="Center" Width="350"
                                       Content="{x:Static netCore:Resources.LedBrightnessOffLabel}" />
                                <NumericUpDown Height="30" Width="200" FormatString="{}{0:#,0}"
                                               Value="{Binding LedBrightnessOff}"
                                               Minimum="1"
                                               Maximum="31" />
                                <Slider Value="{Binding LedBrightnessOff}"
                                        Minimum="1"
                                        Maximum="31"
                                        IsSnapToTickEnabled="True"
                                        TickFrequency="1" Width="200" />
                            </StackPanel>
                            <StackPanel IsVisible="{Binding Builder}" Orientation="Horizontal">
                                <Label VerticalAlignment="Center" Width="350"
                                       Content="{x:Static netCore:Resources.Apa1022020Label}" />
                                <ToggleSwitch HorizontalAlignment="Center" Width="200"
                                              HorizontalContentAlignment="Center"
                                              IsChecked="{Binding Apa102IsFullSize}"
                                              OnContent="{x:Static netCore:Resources.EnabledLabel}"
                                              OffContent="{x:Static netCore:Resources.DisabledLabel}" />
                            </StackPanel>
                            <Label Foreground="Red" Content="{x:Static netCore:Resources.BrightnessNote1}">
                                <Label.IsVisible>
                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                        <Binding
                                            Path="!Branded" />
                                        <Binding Path="!Apa102IsFullSize" />
                                    </MultiBinding>
                                </Label.IsVisible>
                            </Label>
                            <Label Foreground="Red" Content="{x:Static netCore:Resources.BrightnessNote2}"
                                   IsVisible="{Binding !Apa102IsFullSize}" />
                            <Label Foreground="Red" Content="{x:Static netCore:Resources.BrightnessNote3}"
                                   IsVisible="{Binding !Apa102IsFullSize}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label VerticalAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Width="350" Content="{x:Static netCore:Resources.LEDSleepLabel}" />
                            <NumericUpDown FormatString="{}{0:#,0}"
                                           Value="{Binding LedSleep}"
                                           Minimum="0"
                                           Increment="1"
                                           Width="200"
                                           Maximum="65535" HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </StackPanel>
                </Expander>
                <Expander IsVisible="{Binding IsBluetoothTx}" HorizontalAlignment="Stretch" Header="{Binding}"
                          IsExpanded="{Binding BluetoothConfigExpanded}">
                    <Expander.HeaderTemplate>
                        <DataTemplate DataType="viewModels:ConfigViewModel">
                            <Panel HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Image Width="75"
                                           Source="avares://SantrollerConfigurator/Assets/Icons/Combined/Bluetooth.png" />
                                    <Label VerticalAlignment="Center"
                                           VerticalContentAlignment="Center"
                                           Content="{x:Static netCore:Resources.BluetoothTransmitterSettingsLabel}" />
                                </StackPanel>
                                <CheckBox IsChecked="{Binding Connected}" Margin="45 0 0 0"
                                          HorizontalAlignment="Center"
                                          IsEnabled="False"
                                          Content="{x:Static netCore:Resources.ConnectedToReceiverLabel}" />

                                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal"
                                            IsVisible="{Binding !$parent[views:ConfigView].((viewModels:ConfigViewModel)DataContext).Branded}">
                                    <Button
                                        Command="{Binding RemoveBtTxCommand}"
                                        Content="{x:Static netCore:Resources.RemoveLabel}" />
                                </StackPanel>
                            </Panel>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label VerticalAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Width="350" Content="{x:Static netCore:Resources.LocalAddressLabel}" />
                            <Label VerticalAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Width="200" Content="{Binding LocalAddress}" />
                        </StackPanel>
                    </StackPanel>
                </Expander>
                <Expander HorizontalAlignment="Stretch" Header="{Binding}"
