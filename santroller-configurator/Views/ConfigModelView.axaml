                                           Content="{x:Static netCore:Resources.PeripheralSettingsLabel}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="45 0 0 0" HorizontalAlignment="Center"
                                            IsVisible="{Binding HasPeripheral}">
